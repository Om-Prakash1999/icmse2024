ha.com/mediadata/images/Tech_Mahindra.gif"},{"companyName":"CapGemini","logoUrl":"https://images.shiksha.com/mediadata/images/CapGemini.gif"},{"companyName":"Kotak Insurance","logoUrl":"https://images.shiksha.com/mediadata/images/Kotak_Insurance.gif"},{"companyName":"Zydus Cadilla","logoUrl":"https://images.shiksha.com/mediadata/images/Zydus_Cadilla.gif"},{"companyName":"Wipro","logoUrl":"https://images.shiksha.com/mediadata/images/1459772594phpTWDXae.png"},{"companyName":"Square Yards","logoUrl":"https://images.shiksha.com/mediadata/images/1465283975phpQCINy2.png"},{"companyName":"SAP","logoUrl":"https://images.shiksha.com/mediadata/images/SAP.gif"},{"companyName":"ICICI","logoUrl":"https://images.shiksha.com/mediadata/images/ICICI.gif"},{"companyName":"HCL","logoUrl":"https://images.shiksha.com/mediadata/images/HCL.gif"}],"placementPageUrl":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/placement","l2Menu":[{"name":"College Info","url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057","menuSelected":true,"pwa":true,"headingSuffix":null,"headingPrefix":null,"altText":"All About Centurion University Bhubaneswar"},{"name":"Courses & Fees","url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/courses","menuSelected":false,"pwa":true,"headingSuffix":"Courses & Fees 2024","headingPrefix":null,"altText":"Centurion University Bhubaneswar Courses & Fees"},{"name":"Reviews","url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/reviews","menuSelected":false,"pwa":true,"headingSuffix":"Reviews on Placements, Faculty & Facilities","headingPrefix":null,"altText":"Centurion University Bhubaneswar Reviews"},{"name":"Admissions","url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/admission","menuSelected":false,"pwa":true,"headingSuffix":"Admission 2024 - Cutoffs, Eligibility & Dates","headingPrefix":null,"altText":"Centurion University Bhubaneswar Admissions 2024"},{"name":"Placements","url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/placement","menuSelected":false,"pwa":true,"headingSuffix":"Placement - Highest & Average Salary Package","headingPrefix":null,"altText":"Centurion University Bhubaneswar Placements 2024"},{"name":"Cut-Offs","url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/cutoff","menuSelected":false,"pwa":true,"headingSuffix":"Cut off & Merit List 2024","headingPrefix":null,"altText":"Centurion University Bhubaneswar Cut Offs"},{"name":"Infrastructure","url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/infrastructure","menuSelected":false,"pwa":true,"headingSuffix":"Infrastructure Details & Reviews","headingPrefix":null,"altText":"Centurion University Bhubaneswar Infrastructure"},{"name":"Faculty","url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/faculty","menuSelected":false,"pwa":true,"headingSuffix":null,"headingPrefix":"Faculty Details & Reviews","altText":"Centurion University Bhubaneswar Faculty"},{"name":"Compare","url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/compare","menuSelected":false,"pwa":true,"headingSuffix":null,"headingPrefix":"Compare","altText":"Compare Centurion University Bhubaneswar"},{"name":"Q&A","url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/questions","menuSelected":false,"pwa":false,"headingSuffix":null,"headingPrefix":null,"altText":"Centurion University Bhubaneswar Q&A"},{"name":"Scholarships","url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/scholarships","menuSelected":false,"pwa":true,"headingSuffix":"Scholarships","headingPrefix":null,"altText":"Centurion University Bhubaneswar Scholarships"},{"name":"News","url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/news-articles","menuSelected":false,"pwa":true,"headingSuffix":null,"headingPrefix":null,"altText":"Centurion University Bhubaneswar News & Articles"}],"breadCrumb":[{"name":"Home","url":"/","linkText":null,"pwa":true},{"name":"Colleges in Bhubaneswar","url":"/colleges/bhubaneswar","linkText":null,"pwa":true},{"name":"Centurion University Bhubaneswar","url":null,"linkText":null,"pwa":true}],"rankingWidget":{"rankingWidgetData":{"MBA/PGDM":[{"rpId":2,"locationSpecificPosition":5,"stateId":119,"cityId":0,"sourceId":139,"cityName":null,"stateName":"Orissa","publisherName":"Business Today","publisheImageUrl":"https://images.shiksha.ws/public/images/Business-Today-Logo_new.png","allIndiaRank":168,"allIndiaRankString":"168","locationSpecificUrl":"/mba/ranking/top-mba-colleges-in-orissa/2-2-119-0-0?rs[]=139&uaf[]=ranking_source","allIndiaUrl":"/mba/ranking/top-mba-colleges-in-india/2-2-0-0-0?rs[]=139&uaf[]=ranking_source","publisherId":2,"year":2023,"rankBand":false}]},"sortedDisplayOrder":["MBA/PGDM"]},"faq":{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is unique about Centurion University of Technology and Management, Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"*Outcome-Based Education: CUTM focuses on outcome-based education, emphasizing practical skills and industry relevance. The curriculum is designed to bridge the gap between academia and industry requirements, ensuring that students are well-prepared for their future careers. *Socially Oriented Approach: One of the distinctive features of CUTM is its commitment to social responsibility. The university actively engages in various social development initiatives and has established a dedicated social outreach programme called \"Gram Tarang. \" Through this programme, CUTM strives to empower rural communities, promote entrepreneurship, and create sustainable livelihood opportunities. *Industry Partnerships: CUTM has strong industry partnerships and collaborations. It works closely with leading companies and organizations to provide students with internships, industry projects, and exposure to real-world challenges. This helps students gain practical experience and enhances their employability. *Skill Development Centers: CUTM has Skill Development Centers that offer training programs in areas such as automotive, construction, hospitality, agriculture, healthcare, and more. These centers provide students with hands-on learning opportunities and help develop industry-specific skills."}},{"@type":"Question","name":"Is Centurion University of Technology and Management, Bhubaneswar Campus a private or government institute?","acceptedAnswer":{"@type":"Answer","text":"The Centurion University of Technology and Management, Bhubaneswar Campus is a private university. It is located on the Barunei hills. The university offers over 100 courses and is known for its focus on skills, entrepreneurship, and sustainable innovations. It provides a range of programs including graduate, postgraduate, doctoral, diploma, and certificate courses."}},{"@type":"Question","name":"What is Centurion University of Technology and Management, Bhubaneswar Campus famous for?","acceptedAnswer":{"@type":"Answer","text":"The Centurion University of Technology and Management in Bhubaneswar, Odisha, is famous for its unique approach to education and its commitment to skill development, entrepreneurship, and sustainable innovations. The university offers a blend of traditional, applied, and action learning to develop productive citizens. Centurion University is also known for its School of Vocational Training, which is pioneering the concept of vocational training in India."}},{"@type":"Question","name":"How is the college life at Centurion University of Technology and Management, Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"Campus Environment: CUTM boasts a spacious and well-equipped campus that creates a conducive learning environment. With modern infrastructure, well-designed classrooms, libraries, and recreational spaces, the campus provides students with everything they need for their academic and extracurricular pursuits. Academic Programs: CUTM offers a diverse range of academic programs spanning various disciplines, including engineering, management, agriculture, applied sciences, and more. The curriculum is carefully designed to strike a balance between theoretical knowledge and practical skills, ensuring that students develop a strong academic foundation. Faculty and Staff: The faculty members at CUTM are highly dedicated, knowledgeable, and supportive. They play a crucial role in guiding students, conducting engaging classes, and providing mentorship. The staff members are also available to assist students with administrative and logistical matters, creating a supportive environment. Student Activities and Clubs: CUTM encourages student engagement through a wide range of clubs, student organizations, and extracurricular activities. Cultural events, sports competitions, technical competitions, and social initiatives provide students with ample opportunities for personal growth, skill development, and fostering long-lasting friendships. Industry Exposure and Internships: CUTM places a strong emphasis on industry-oriented education. The university collaborates with industries and organizations to offer internships, industrial visits, guest lectures, and workshops. These experiences provide students with practical exposure to the corporate world, bridging the gap between academia and the professional sphere. Cultural and Sports Events: Throughout the year, CUTM organizes captivating cultural and sports events, infusing the campus with a lively and vibrant atmosphere. Students can showcase their talents in music, dance, drama, and sports through competitions, festivals, and annual gatherings. These events promote camaraderie and celebrate the diverse student community. Social Initiatives and Community Service: CUTM instills a sense of social responsibility and community engagement in its students. Active participation in community service initiatives, volunteering activities, and social awareness campaigns allows students to contribute positively to society and develop a strong sense of social consciousness."}},{"@type":"Question","name":"What are the top courses offered at Centurion University of Technology and Management, Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"The top courses offered at Centurion University of Technology and Management, Bhubaneswar include: Bachelor of Technology (B.Tech) Bachelor of Business Administration (BBA) Master of Science (M.Sc) Bachelor of Science (B.Sc) Master of Business Administration (MBA) Ph.D. Polytechnic The university offers a wide range of courses at various levels, including diploma, undergraduate, postgraduate, and doctoral programs. Some of the popular courses at the undergraduate level are B.Tech, BBA, and B.Sc, while at the postgraduate level, M.Sc and MBA are preferred choices. The university also offers a Ph.D. program for those interested in pursuing research and advanced studies."}},{"@type":"Question","name":"How can I get direct admission in MCA at Centurion University?","acceptedAnswer":{"@type":"Answer","text":"MCA Admission Criteria at Centurion University Bhubaneswar- Major criteria: JEE Mains/OJEE score/rank and graduation with 50% Course duration: 2 years full-time Tuition fee: INR 1.9 lakh Eligibility: Bachelor's degree in Computer Science Engineering or equivalent degree, or B.Sc./B.Com./B.A. with Mathematics at 10+2 or graduation level (with additional bridge courses)"}},{"@type":"Question","name":"What is the fee for various courses offered by Centurion University of Technology and Management, Bhubaneswar Campus?","acceptedAnswer":{"@type":"Answer","text":"The fee for various courses offered by Centurion University of Technology and Management, Bhubaneswar Campus: BBA: Rs 66,000 per year B.Tech: Rs 1.42 Lacs per year M.Sc: Rs 80,000 per year MBA: Rs 7.5 Lacs per year M.Tech: Rs 78,750 per year Polytechnic: Rs 52,500 per year BA: Rs 1,05,000 Diploma in engineering: Rs 1,53,750 BCA: Rs 70,000 per year"}},{"@type":"Question","name":"What are the courses offered at Centurion University of Technology and Management, Bhubaneswar Campus?","acceptedAnswer":{"@type":"Answer","text":"Centurion University of Technology and Management, Bhubaneswar offers a wide range of courses across various disciplines. Some of the courses available at the Bhubaneswar campus include BBA, B.Tech, M.Sc, MBA, M.Tech, Polytechnic, BA, Diploma in Engineering, BCA, commerce, pharmacy, agriculture management, medical, paramedical and computer applications."}},{"@type":"Question","name":"Is Centurion University of Technology and Management, Bhubaneswar Campus good for engineering?","acceptedAnswer":{"@type":"Answer","text":"Centurion University of Technology and Management, Bhubaneswar is a reputed educational institution offering a wide range of engineering courses. It is highly regarded for its engineering programs and industry collaborations. The university's hands-on approach to learning, strong links with industry and commitment to skills development make it a preferred choice for engineering aspirants."}},{"@type":"Question","name":"Which is the top course at Centurion University of Technology and Management, Bhubaneswar Campus?","acceptedAnswer":{"@type":"Answer","text":"Centurion University of Technology and Management, Bhubaneswar is a reputed educational institution offering a wide range of courses. The university is a top MBA college in Bhubaneshwar, Odisha. The national ranking framework ranked Centurion University Technology and Management number one for MBA. Some Popular courses from the university include B.Tech, MBBS, ME/M. Tech, B.Sc, BA, B.Com, etc."}},{"@type":"Question","name":"How do I get a seat at Centurion University?","acceptedAnswer":{"@type":"Answer","text":"The University conducts a common Entrance Exam for the UG & PG courses. The Entrance Exam dates for the academic year 2023: 30th of every month starting from 30th Dec 2022 to 30th August 2023. Last date of applying will be 25 Aug 11:59 PM with a minimum fee of INR 600. To get admission in Centurion University you need to follow the mentioned below steps: Step 1: Apply for the entrance exam CUEE- 2023, through the official website. The mode of examination will be Online/Offline. Step 2: The registered candidates will be informed about the exam time, link, credentials, etc. via E-mail. Step 3: Result Declaration, Reporting for Counselling and admission. Step 4: Documentation process Step 5: Reporting details (date, time, schedule, etc.)"}},{"@type":"Question","name":"What is the mode of application at Centurion University Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"The mode of application is Online & Offline as well. The Entrance Exam dates for the academic year 2023: 30th of every month starting from 30th Dec 2022 to 30th August 2023. Last date of applying will be 25 Aug 11:59 PM with a minimum fee of INR 600. The applicants can apply from the official website of the CUTM. For the applicants who are appearing for the online mode need to give proctored based test, and for the offline applicants, should report to Notified Test Centre or at the University campus. To get admission in Centurion University you need to follow the mentioned below step: Step 1: Apply for the entrance exam CUEE- 2023, through the official website. The mode of examination will be Online/Offline. Step2: The registered candidates will be informed about the exam time, link, credentials, etc. via E-mail. Step 3: Result Declaration, Reporting for Counselling and admission. Step 4: Documentation process Step 5: Reporting details (date, time, schedule, etc.)"}},{"@type":"Question","name":"Does Centurion University offer Diploma courses, what is the eligibility criteria?","acceptedAnswer":{"@type":"Answer","text":"Yes, Centurion University offers Diploma courses with various programme like School of Paramedics & allied Health Science, School of Pharmacy and Life Sciences and School of Vocational Training, refer to the table for more understanding. Diploma Courses Eligibility School of Paramedics & allied Health Science (8 courses) Class 12, CUEE School of Pharmacy and Life Sciences Class 12, CUEE School of Vocational Training (13 courses) Class 12, CUEE"}},{"@type":"Question","name":"Can I get direct admission to Centurion University of Technology and Management, Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"Admissions are purely merit based and will be provided based on the students performance in the entrance exams.Like Btech admission Centurion University need twelve result or diploma result performence. Other branches have other types of performances"}},{"@type":"Question","name":"Which are top industries that recruit from Centurion University of Technology and Management, Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"Centurion University of Technology and Management, Bhubaneswar is a reputed university that attracts recruiters from various fields. The University is the place where many top companies recruit talent in fields such as finance, technology, engineering, marketing and advertising, management, accounting, human resources, IT, education, start-ups, banking, retail, pharmaceuticals and hospitality. It functions as a platform for, infrastructure, automobiles, etc. Some of the top companies that have recruited from the university include Accenture, ITC, Jio, and Cipla."}},{"@type":"Question","name":"What is the highest placement package offered to students of Centurion University of Technology and Management, Bhubaneswar Campus?","acceptedAnswer":{"@type":"Answer","text":"Centurion University of Technology and Management, Bhubaneswar Campus provide nearly 80% of the students enrolled at our school. TCS is one of the largest recruitment firms in the world. The highest salary package offered is 8 LPA. The lowest remuneration package we offer is 3 LPA."}},{"@type":"Question","name":"What is the average package offered at Centurion University of Technology and Management, Bhubaneswar Campus?","acceptedAnswer":{"@type":"Answer","text":"The Centurion University of Technology and Management's placements for 2023 are illustrated in the following manner: - The maximum package available was INR 13.8 Lacs per year. - A remarkable 1513 of the 1684 students who applied for placement did so, yielding a placement rate of 90%. - More than 2300 job offers were sent to students, and over 200 businesses actively took part in the placements. 47 pupils received job offers with salaries surpassing 9 Lacs annually, which is noteworthy. - In 2023, Accenture, ITC, Jio, Cipla, Justdial, and many others were among the top employers."}},{"@type":"Question","name":"Does Centurion University of Technology and Management, Bhubaneswar Campus offer better placements than C. V. Raman Global University?","acceptedAnswer":{"@type":"Answer","text":"Both Centurion University of Technology and Management, Bhubaneswar Campus, and C. V. Raman Global University have good placement records. The Centurion University of Technology and Management offers about 90% placement with the highest package being 10 LPA and an average package of 3-4 LPA. On the other hand, at C. V. Raman Global University the highest salary package offered was 40 LPA by Amazon. In conclusion, both universities have strong placement records. However, the choice between the two should depend on your preferred course and the companies you aspire to work for."}},{"@type":"Question","name":"Does Centurion University of Technology and Management, Bhubaneswar Campus have good placements?","acceptedAnswer":{"@type":"Answer","text":"Yes, the college have Good placements as we can see the records for 2023 as follows: This In the placements at the Centurion University of Technology and Management for 2023: - An astounding 1513 out of a total of 1684 students were placed in jobs, yielding a high placement rate of 90%. - Surprisingly, students received over 2300 job offers, meaning that many had a variety of employment options to select from. - More than 200 recruiters took part in the placement process, which was lively and showed off a variety of prospects for the students."}},{"@type":"Question","name":"What is the highest package of Centurion University BTech?","acceptedAnswer":{"@type":"Answer","text":"Centurion University Bhubaneswar has a strong placement record. In 2022, over 50% of students were placed, with the highest salary package offered being INR 5.00 LPA and the lowest salary package being INR 2.5 LPA. The placement cell works with a wide range of companies, including IT, engineering, finance, and consulting firms. In 2022, some of the top recruiters at Centurion University Bhubaneswar included: Infosys, Wipro, TCS, Amazon, Cognizant, Tech Mahindra, Capgemini, IBM, HCL. The most popular sectors for placements were IT, engineering, and finance. The top recruiters were from India, but there were also some international recruiters."}},{"@type":"Question","name":"What rank is necessary for MBA at Centurion University of Technology and Management, Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"The overall cutoff for MBA is 25 percentile. Cutoff trends of the university admission to various department vary programme wise and with each academic year and the same is privy to the office of the university."}},{"@type":"Question","name":"What is hostel fees at Centurion University of Technology and Management, Bhubaneswar Campus?","acceptedAnswer":{"@type":"Answer","text":"Centurion University hostel fees are :- A/C room with attached toilet (3 Seater): Rs. 1,25,000/- Non A/C room with attached toilet (4 Seater): Rs. 95,000/- Non A/C room with common toilet (5 Seater): Rs. 80,000/-. ."}},{"@type":"Question","name":"What is fee for BTech at Centurion University?","acceptedAnswer":{"@type":"Answer","text":"BTech at Centurion University is of four year course for full time, the CUTM offers eight Specialisation in BTech. The variation in fee depends on the specialsation provided by the University. Parameters Details Course BTech Eligibility CUEE, JEE Mains Total Tuition Fee INR 5.67 Lacs - INR 6.00 Lakh"}},{"@type":"Question","name":"How can I check my merit list at Centurion University of Technology and Management, Bhubaneswar Campus?","acceptedAnswer":{"@type":"Answer","text":"The Centurion University of Technology and Management (CUTM), located in Bhubaneswar, Odisha, is a pioneering institution in the field of higher education. You can visit the official website of Centurion University of Technology and Management to check your merit list. A formal Admission Letter informing each candidate of their successful selection and merit will be sent to their registered email address after they have been chosen."}},{"@type":"Question","name":"What is the fee for MBA at Centurion University of Technology and Management, Bhubaneswar Campus?","acceptedAnswer":{"@type":"Answer","text":"The tuition fee for MBA at Centurion University of Technology and Management, Bhubaneswar Campus is ?2.10 Lacs for the first year. The total tuition fee for the two-year programme is ?4.20 lakhs."}},{"@type":"Question","name":"What is the seat intake for B.Tech at Centurion University?","acceptedAnswer":{"@type":"Answer","text":"The seat intake of BTech with various specialisation is mention below in thr table for better understanding: BTech Course Seat Intake BTech in Computer Science and Engineering 60 BTech in Aerospace Engineering - BTech in Biotechnology Engineering - BTech in Mechanical Engineering 60 BTech in Civil Engineering 60 BTech in Electrical and Electronic Engineering 60 BTech in Mining Engineering - BTech in Electronics and Communication Engineering 60"}},{"@type":"Question","name":"Can I get direct admission in Centurion University BTech?","acceptedAnswer":{"@type":"Answer","text":"The admission process in Centurion University Bhubaneswar for BTech course is mentioned below: Register for CUEE 2023 and pay the application fee of INR 600. Appear for the CUEE exam either online or at a notified test center. If you qualify the exam, you will be eligible for provisional admission. Pay the minimum fee and submit the original documents for verification. Report to the campus on the notified date. Here are some additional details: The CUEE exam is conducted in online mode The application fee can be paid online or through demand draft Pay the minimum fee for provisional admission The original documents that need to be submitted for verification include: Qualifying mark sheet, Certificate/rank/score card, Aadhar card, PAN card, Payment receipt, Passport-sized photographs The notified date for reporting to the campus will be mentioned in the provisional admission letter."}},{"@type":"Question","name":"What is the last date to apply for the BBA in Centurion University Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"The last date of applying CUEE for BBA in Centurion University BBSR is 25th Aug 2023. The exam will be on every 30th of the month, starting from 30th Dec 2022 – 30th Aug 2023. DATES UPCOMING EVENTS 30 Jun 2023 BBA CUEE 2023 30 Jul 2023 BBA CUEE 2023 25 Aug 2023 Last date for applying CUEE 2023 30 Aug 2023 BBA CUEE 2023"}},{"@type":"Question","name":"Is Centurion University good for BTech?","acceptedAnswer":{"@type":"Answer","text":"The total tuition fee for the course BTech is ranging from INR 5.67 Lacs – INR 6 Lacs for four years. The fee may vary due to the different specialisation offered by the Centurion University. The mentioned fee has been taken from unofficial source. Hence, the data might get vary. The overall rating is 3.8 based on verified reviews, the Placements records of median salary is 3.50 lakh. The eligibility criteria for BTech course offered by the university is Class 12 (Physics, Chemistry, Math’s) with 50% aggregate (5% relaxation for reserved category) and CUEE score/rank."}},{"@type":"Question","name":"What are the courses offered by the Centurion University BTech?","acceptedAnswer":{"@type":"Answer","text":"Centurion University BTech course offers eight specialisation under BTech Programme which are listed below: BTech in Computer Science and Engineering BTech in Aerospace Engineering BTech in Biotechnology Engineering BTech in Mechanical Engineering BTech in Civil Engineering BTech in Electrical and Electronic Engineering BTech in Mining Engineering BTech in Electronics and Communication Engineering"}},{"@type":"Question","name":"How are MBA placements at Centurion University of Technology and Management, Bhubaneswar Campus?","acceptedAnswer":{"@type":"Answer","text":"CUTM has a good placement record, with a placement rate of over 90% in recent years. The average salary package offered to students is also impressive, with the average salary package for the 2023 batch being over INR 6 LPA."}},{"@type":"Question","name":"How many recruiters participated in Centurion University of Technology and Management, Bhubaneswar Campus placements?","acceptedAnswer":{"@type":"Answer","text":"According to the Centurion University of Technology and Management (CUTM) website, more than 200 recruiters participated in the Bhubaneswar campus placements in 2023. Some of the top recruiters included Accenture, ITC, Jio, Cipla, and Justdial."}},{"@type":"Question","name":"What entrance exam scores do Centurion University of Technology and Management, Bhubaneswar Campus accept for admission to MBA?","acceptedAnswer":{"@type":"Answer","text":"The Centurion University of Technology and Management, Bhubaneswar Campus, conducts its own entrance examination known as CUEE for admission to all its courses. However, for the MBA program, students who have qualified in national-level examinations like CAT, XAT, MAT, or CET are exempted from the CUEE. A bachelor's degree in any subject with a score of 50%, including the arts, sciences, commerce, or engineering, is mandatory for admission."}},{"@type":"Question","name":"How many students can do an MBA at Centurion University of Technology and Management, Bhubaneswar Campus?","acceptedAnswer":{"@type":"Answer","text":"Centurion University of Technology and Management, Bhubaneswar Campus has an intake of 60 students for the MBA program."}},{"@type":"Question","name":"Can I get Centurion University of Technology and Management, Bhubaneswar Campus with 500 rank in JEE?","acceptedAnswer":{"@type":"Answer","text":"It is straightforward to apply to Centurion University: 1. Your CUEE score and a personal interview are required for admission to the majority of courses. They also take JEE Main scores into account if you're applying to a BTech degree. For BTech, you need a CUEE or JEE Main rank within 50,000 or within 3 lakh. 3. Using the names of the chosen students, the university compiles a merit list. There you go!"}},{"@type":"Question","name":"Is OJEE required for MBA at Centurion University of Technology and Management, Bhubaneswar Campus?","acceptedAnswer":{"@type":"Answer","text":"No, OJEE is not required for MBA at Centurion University of Technology and Management, Bhubaneswar Campus. The eligibility criteria for the MBA program at CUTM is the completion of the degree in any discipline with passing marks. It is a private university located in Bhubaneswar, India. It offers a wide range of courses across various disciplines including MBA, Engineering, Vocational studies and etc."}},{"@type":"Question","name":"Q. Is Centurion University Bhubaneswar a recognised university campus?","acceptedAnswer":{"@type":"Answer","text":"A. Centurion University Bhubaneswar is affiliated with CUTM Paralakhemundi, which is recognised by NAAC with ‘A’ grade. Established in 2005, Centurion University of Technology and Management (CUTM) is a multi-sector, private university located in Odisha, India. The main campus of CUTM is located at Paralakhemundi (Gajapati district). With over 600 expert instructors and over 20,000 students across the world, the University has other campuses located in Bhubaneswar and Visakhapatnam (or Vizianagaram) along with three regional campuses located in Rayagarh, Balangir (or Bolangir) and Balasore."}},{"@type":"Question","name":"Q. Which courses are offered at Centurion University Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"A. Centurion University Bhubaneswar offers a range of diploma, UG, PG, research-level and certificate programmes offered through various departments working under it. Some of the popular courses offered this campus of CUTM include BTech, BBA, BCom, BSc, MTech, MBA and MSc among various others. Centurion University BBSR admission 2022 to all the programmes is based on scores obtained in Centurion University Entrance Exam (CUEE) conducted by the University. Centurion University, Bhubaneswar also accepts a few nation-level entrance exam scores to provide admission in courses, including MBA, BTech, BDes, BArch and MTech."}},{"@type":"Question","name":"Q. What is admission process at Centurion University Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"A. Candidates willing to take admission to Centurion University Bhubaneswar for all the UG and PG courses are required to have a valid score in CUEE test conducted by the University or course-specific entrance rest (accepted by the University) provided they meet with the minimum eligibility criteria set by the University. For diploma and certificate courses, however, admission is based on merit scores in the last qualifying exam."}},{"@type":"Question","name":"Q. What is CUEE stand for?","acceptedAnswer":{"@type":"Answer","text":"A. CUEE stands for Centurion University Entrance Exam. It is conducted by Centurion University (CUTM), Odisha for admissions to various undergraduate and postgraduate courses offered at the various campuses of the University. CUEE 2020 will be conducted in online mode or will be a CBT (Computer Based Test)."}},{"@type":"Question","name":"Q. Does Centurion University Bhubaneswar campus offer residential facilities?","acceptedAnswer":{"@type":"Answer","text":"A. Yes, Bhubaneswar campus of Centurion University offers hostel facilities to the students. Some of the other campus facilities provided at Centurion University Bhubaneswar are as follows: Air-conditioned classrooms A fully Wi-Fi campus Well-equipped Conference hall and Seminar hall Library Transport and Medical facilities Full-time internet connectivity"}},{"@type":"Question","name":"Q. Does Centurion University Bhubaneswar have any industrial collaborations?","acceptedAnswer":{"@type":"Answer","text":"A. Yes, a number of programmes such as JAVA certification in association with IBM, Network Certification in association with CISCO, DB2 training Certification in association with IBM, and Campus Connect in association with Infosys are organized for the active development of students on regular intervals."}},{"@type":"Question","name":"Q. What is the application process at Centurion University Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"A. Centurion University's admission process is conducted both online and offline. Candidates seeking admission to any of the courses, need to apply on the official website by paying an amount of INR 600 to INR 1,500. The entire application process is shown below with the help of application screenshots: Step 1: Visit the official website (www.cutm.ac.in). On its homepage, register yourself by providing an email id. Step 2: Fill up the application form by providing all your personal details. Step 3: Complete the form by providing your educational qualifications and press submit. Step 4: Pay online through net banking/ debit card/ credit card."}},{"@type":"Question","name":"Q. How is Centurion University Bhubaneswar in terms of foreign exposure?","acceptedAnswer":{"@type":"Answer","text":"A. Centurion University Bhubaneswar has signed MoUs with a number of international institutes and universities to offer world-class education and global exposure to its students at the central level across all its campuses. Some of the Universities CUTM is having tie-ups with include, University of California, Deakin University (Australia), Plymouth University (England), Box Hill Institute (Australia) and Holmesglen Institute (Australia) among various others."}},{"@type":"Question","name":"Q. Are there any scholarships offered at Centurion University Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"A. Centurion University of Technology and Management, Bhubaneswar offers various scholarships based on prior academic record during admission and a few scholarships based on semester-wise performance for the years to follow. In addition to these, ample scholarships are offered to reserved and minority category students as listed below: PRERANA post-matric scholarship for SC/ST/OBC and SEBC District Welfare Office (Odisha) Minority scholarship from District Welfare Office (Odisha) National scholarship Jindal Foundation scholarship (Sitaram Jindal) Times of India scholarship"}},{"@type":"Question","name":"Q. How are the placements at Centurion University Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"A. CUTM has a centralised placement cell operating from the main campus. Some of the top recruiters that have visited Centurion University Bhubaneswar campus for placements include Infosys, IBM, Cognizant, IndiaMart, Accolite Digital, Paytm, LensKart, Volvo and Mindtree, among others."}},{"@type":"Question","name":"How is CGPA calculated in Centurion University of Technology and Management, Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"The calculation of CGPA (Cumulative Grade Point Average) is based on the grades obtained in the semester exams for individual subjects. The gradesheet for the semester exam results includes both SGPA (Semester Grade Point Average) and CGPA. SGPA represents the average grade points earned in a particular semester. It is calculated by dividing the total grade points obtained in all subjects during the semester by the total number of credits assigned to those subjects. CGPA, on the other hand, represents the overall average grade points earned by a student across multiple semesters. It is calculated by dividing the total grade points obtained in all semesters by the total number of credits completed in those semesters. The gradesheet provides a comprehensive overview of the performance in each semester, as reflected by the SGPA, and the cumulative performance throughout the academic program, as indicated by the CGPA. These indicators help students and academic institutions evaluate and track academic progress accurately."}},{"@type":"Question","name":"What PGs and hostels are available close to Centurion University of Technology and Management, Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"Yes, PGs and hostels are available in Centurion University. Centurion University have different hostels :- AC Hostels, Non-AC hostels. And also there Non-AC with attached bathroom. And these hostels prices are also different."}},{"@type":"Question","name":"Can I get direct admission to Centurion University of Technology and Management, Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"Admissions are purely merit based and will be provided based on the students performance in the entrance exams.Like Btech admission Centurion University need twelve result or diploma result performence. Other branches have other types of performances"}},{"@type":"Question","name":"What is the dress code at Centurion University of Technology and Management, Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"Students have to wear proper formal dress code and we have different dress for different courses in our university.You cannot get college dresses from outside since colleges manufacture them and charge for them."}},{"@type":"Question","name":"What are some helpful tips for students starting their first year at Centurion University of Technology and Management, Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"Make a proper notes. Follow what teacher says. Make a disciplined, timetable."}},{"@type":"Question","name":"Does Centurion University of Technology and Management, Bhubaneswar have international collaborations or MoUs?","acceptedAnswer":{"@type":"Answer","text":"Yes, Centurion University of Technology and Management (CUTM), Bhubaneswar, has actively pursued collaborations and Memorandums of Understanding (MoUs) with international institutions and organizations. These collaborations aim to foster academic exchanges, research collaborations, and international exposure for students and faculty members. While specific collaborations may vary over time, here are some examples of international collaborations and MoUs that CUTM has had in the past: 1. International Collaborations: CUTM has collaborated with renowned international universities and organizations to promote academic cooperation and exchange programs. These collaborations may include student exchange programs, faculty exchange programs, joint research projects, and sharing of academic resources. 2. Skill Development Partnerships: CUTM has partnered with international institutions and organizations to enhance skill development initiatives. These collaborations focus on sharing best practices, curriculum development, and training programs to equip students with industry-relevant skills. 3. Research Collaborations: CUTM has established research collaborations with international institutions to foster joint research projects, knowledge exchange, and technological advancements. These collaborations often involve faculty members and researchers from both institutions working together on specific research areas of mutual interest. 4. Study Abroad Programs: CUTM may have agreements with international universities to offer study abroad programs for its students. These programs allow students to spend a semester or a year studying at partner universities, gaining international exposure and broadening their educational experience. 5. Industry Collaborations: CUTM may have partnerships with international industries or organizations to promote industry-academia collaboration. These collaborations facilitate internships, industry visits, guest lectures, and industry-driven projects, providing students with practical exposure and industry insights. It's important to note that collaborations and MoUs can evolve over time, and new partnerships may be established while existing ones may change or conclude. Therefore, I recommend visiting the official website of Centurion University of Technology and Management or contacting the university directly to get the most accurate and up-to-date information on the current international collaborations and MoUs in place. The university's international affairs office or academic department can provide detailed information on the specific collaborations and opportunities available to students."}},{"@type":"Question","name":"How are the faculty members at the Centurion University of Technology and Management, Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"A CUTM faculty member is typically well-qualified and holds relevant academic degrees. They are extremely helpful too."}},{"@type":"Question","name":"Are there any seat reservations at Centurion University of Technology and Management, Bhubaneswar Campus?","acceptedAnswer":{"@type":"Answer","text":"Yes, you can get a seat reserved at Centurion University of technology and management. Students Can pay some amount of the confirm their seat."}},{"@type":"Question","name":"What is the student strength in Centurion University of Technology and Management, Andhra Pradesh?","acceptedAnswer":{"@type":"Answer","text":"The student strength in Centurion University of Technology and Management, Andhra Pradesh is as followed as in first-year total student intake in the year 2022 was 1.05k, with a male-to-female ratio of 6:4, I. e. 60% male and 40% female."}},{"@type":"Question","name":"What happens if a student fails internal exams in Centurion University of Technology and Management, Bhubaneswar Campus?","acceptedAnswer":{"@type":"Answer","text":"If a student fails internal exams in Centurion University of Technology and Management, Bhubaneswar Campus they could apply for the EOD with a fine if they do not pass an internal test. Then, once again you can give the test next semester."}},{"@type":"Question","name":"What will happen if someone misses the internal exam in Centurion University of Technology and Management, Bhubaneswar campus?","acceptedAnswer":{"@type":"Answer","text":"If a student's absent from an internal test, for example because of health problems. He will be allowed to retake the exam, but they must provide reliable documentation of their absence. The student shall be approved by both the Head of Department and the class coordinator. Most re-exams take place during study breaks at the end of the semester, so if you applied for a re-exam, you need to be ready."}},{"@type":"Question","name":"How is mess food at Centurion University of Technology and Management, Bhubhneshwar campus?","acceptedAnswer":{"@type":"Answer","text":"Mess food at Centurion University of Technology and Management serves breakfast, lunch, evening tea and dinner every day and the weekly menu is available with the mess in-charge. The food served is of high quality and meets the nutritional quality standards."}},{"@type":"Question","name":"Does Centurion University of Technology and Management, Bhubaneswar offer hostel facilities?","acceptedAnswer":{"@type":"Answer","text":"The University of Centurion has a number of accommodation, including AC and non AC dormitory rooms with attached bathrooms. There's a difference in these hotel charges. Both male and female can get a good accommodation with all amenities."}},{"@type":"Question","name":"What specialisation does Centurion University of Technology and Management, Bhubaneswar offer in their Medical courses?","acceptedAnswer":{"@type":"Answer","text":"Fields in which Centurion University of Technology and Management, Bhubaneswar provide specialization in Medical courses are Optometry, Medical Laboratory Technician, Radiation Technology, Physiotherapy, Anesthesia, Clinical Microbiology."}},{"@type":"Question","name":"Is Centurion University of Technology and Management, Bhubaneswar Campus as good as C. V. Raman Global University?","acceptedAnswer":{"@type":"Answer","text":"Both Centurion University of Technology and Management, Bhubaneswar Campus and C. V. Raman Global University are reputed institutions in Bhubaneswar, Odisha, India. Centurion University of Technology and Management has been recognized as a Center of Excellence by the Ministry of Skill Development and Entrepreneurship, Government of India. On the other hand, C. V. Raman Global University is also a well-regarded institution. It has been ranked 101 for Overall by NIRF in 2023. In conclusion, both universities have their strengths and areas for improvement. The choice between the two would depend on your personal preferences and academic goals."}},{"@type":"Question","name":"How is the overall infrastructure of Centurion University Bhubaneswar?","acceptedAnswer":{"@type":"Answer","text":"[Source: B.Pharma students & alumni]. Based on the reviews, the overall infrastructure of Centurion University Bhubaneswar is well-maintained and provides adequate facilities for its students. Reviewers have praised the university's infrastructure, including its well-built and maintained buildings, hostels with Wi-Fi and other amenities and fully equipped laboratories. Some reviewers have noted that the university's library is stocked with a wide range of books relevant to the courses offered. Additionally, the university offers free skill courses alongside its main courses, providing students with opportunities to develop their skills beyond their academic studies. Summary: Centurion University Bhubaneswar has a well-maintained infrastructure with modern facilities such as hostels, libraries, laboratories and sports facilities. The university offers a range of programs and provides students with access to a diverse range of resources and opportunities to develop their skills. Above answer is based on below reviews Well build and maintained infr . by Pankaj Class rooms are quite good for . by Sukarna The classrooms and labs are ve . by Ashirbad There is no doubt that no one . by Anshuman All the facilities are availab . by Milan"}},{"@type":"Question","name":"Can I get into Centurion University of Technology and Management, Bhubaneswar Campus with 75% in class 12?","acceptedAnswer":{"@type":"Answer","text":"The Centurion University of Technology and Management (CUTM), located in Bhubaneswar, Odisha, is a pioneering institution in the field of higher education. To be eligible for the Centurion University of Technology and Management, Candidates must have earned at least a 50% grade point average in their Class 12 exams to be eligible. For SC/ST applicants, there is a 5% mark reduction, making the admissions process more accessible and inclusive."}}]},"similarWidgetHeading":"Other Centurion University of Technology and Management, Bhubaneswar Campus institutes","predictorUrlFlag":true,"beaconData":{"hierarchy":[{"stream_id":1,"substream_id":0,"specialization_id":451,"primary_hierarchy":0},{"stream_id":1,"substream_id":0,"specialization_id":188,"primary_hierarchy":0},{"stream_id":1,"substream_id":0,"specialization_id":251,"primary_hierarchy":0},{"stream_id":8,"substream_id":15,"specialization_id":130,"primary_hierarchy":0},{"stream_id":1,"substream_id":0,"specialization_id":0,"primary_hierarchy":1}],"baseCourseId":101,"credential":{"id":9,"name":"Degree"},"level":{"id":15,"name":"PG"},"deliveryMethod":{"id":33,"name":"Classroom"},"educationType":{"id":20,"name":"Full Time"},"cityId":912,"stateId":119,"flagshipCourseId":282634,"examIds":[13658,9886,14687]},"ownership":"Private","reviewData":{"aggregateReviewWidget":{"averageRating":{"mean":3.909649109631254},"facultyRating":{"mean":4.087719298245614},"campusFacilitiesRating":{"mean":4.105263157894737},"avgSalaryPlacementRating":{"mean":3.460526315789474},"crowdCampusRating":{"mean":4.065789473684211},"moneyRating":{"mean":3.8289473684210527},"internshipRating":{"mean":0},"partTimeWorkRating":{"mean":0},"postStudyJobsRating":{"mean":0},"qualityOfFacultyRating":{"mean":0},"studentLifeRating":{"mean":0},"valueForMoneyRating":{"mean":0},"publicTransportationRating":{"mean":0},"permanentImmigrationRating":{"mean":0},"safetyRating":{"mean":0},"foodOptionsRating":{"mean":0},"discriminationFacedDTO":{"discriminationFacedRarely":0,"discriminationFacedNever":0,"discriminationFacedSometimes":0,"discriminationFacedVeryCommon":0},"universityAdjectives":{"adjectiveOne":null,"adjectiveTwo":null,"adjectiveThree":null,"adjectiveFour":null},"verifiedCount":228,"unverifiedCount":35,"intervalRatingCount":{"1":12,"2":29,"3":77,"4":110},"intervalRatingCountForPlacement":{"1":53,"2":46,"3":73,"4":56},"intervalRatingCountForFaculty":{"1":20,"2":34,"3":73,"4":101},"intervalRatingCountForInfrastructure":{"1":12,"2":35,"3":93,"4":88}},"reviewTuplesDTO":{"reviewData":[{"reviewId":3381849,"averageRating":3.4,"facultyRating":3,"campusFacilitiesRating":4,"avgSalaryPlacementRating":3,"reviewContent":{"placementDescription":"Around 50% of the students were placed this year from my course/department, last year it was 70-80%. The highest package was around 10lacs and the lowest was 3 LPA with average of 5lacs here. Top recruiting companies are IT industries like Wipro and Dell, Flipkart. More than 70% of the students got internship from my course. Top role offered was data security and web tester.","infraDescription":"Facilities and infrastructure available for my course and department is very good. Wi-Fi is very good in campus. Labs are nice in every department, Classrooms are good and library is nice, too. Quality of facilities in hostel is good, mess food is acceptable, medical facilities are very good here. Sports and games are available here.","facultyDescription":"Teachers are helpful here obviously, they are well qualified and knowledgeable. Teaching quality is also very good in my department. Course curriculum is relevant and it makes the students industry ready. Semester exams are normal and the pass percentage is more than 90%.  ","reviewTitle":"Good placements in 2022. Good location, beautiful and natural.","reviewDescription":"Good college for this course. Events are good, fests are also good here, very cultural. Campus crowd is manageable. Connectivity is good here, campus surrounding is nice and good location. Scholarship scheme is not available here. ","lowRatingReason":null,"highRatingReason":null,"knowBeforeJoining":null},"yearOfGraduation":2025,"crowdCampusRating":4,"moneyRating":3,"creationDate":"2023-12-27","firstname":"Prince kumar","lastname":null,"reviewStatus":"published","helpfulCount":0,"publicMedia":[],"profilePicUrl":null,"showInstituteReply":false,"courseId":191590,"streamId":2,"abroadRatings":null,"discriminationFaced":null,"stayWhileStudying":null,"lowRatingMasterLabel":null,"highRatingMasterLabel":null,"foodSpending":null,"accommodationSpending":null,"transportationSpending":null,"monthlyExpenses":null,"currency":"INR","hoursSpentPreparing":null,"averageAnnualSalary":null,"anonymous":false},{"reviewId":3378913,"averageRating":3.4,"facultyRating":3,"campusFacilitiesRating":4,"avgSalaryPlacementRating":3,"reviewContent":{"placementDescription":"About 50% of the students were placed in my course. The highest package offered was 6 lacs, and the lowest was 2 lacs, with an average of 3 lacs. The top recruiting companies are Searchingyard and Bajaj Capital. About 60% of the students got internships from my course. The top role offered was business development executive.","infraDescription":"The facilities and infrastructure available for my course or department are good; Wi-Fi is good; labs are okay; and classrooms are good.\nThe library is well-stocked and beautiful. Hostel facilities are okay, and mess food is acceptable. The canteen is nice, medical facilities are available, and a variety of sports and games are present here.","facultyDescription":"Teachers are really helpful here; they are well qualified and knowledgeable. The teaching quality is very good here. This course curriculum is relevant and it makes the students industry-ready with practical and theoretical knowledge. Semester exams are not too hard to score; the pass percentage is more than 90%.","reviewTitle":"Absolutely satisfied because of faculty members. Good placement this year (2023).","reviewDescription":"I chose this course because of its scope. Events and fests are not good here; the campus crowd is not too large; connectivity is manageable; and the campus surroundings are beautiful and nice.","lowRatingReason":null,"highRatingReason":null,"knowBeforeJoining":null},"yearOfGraduation":2024,"crowdCampusRating":4,"moneyRating":3,"creationDate":"2023-12-24","firstname":"Garugu Laxmi","lastname":null,"reviewStatus":"published","helpfulCount":0,"publicMedia":[],"profilePicUrl":null,"showInstituteReply":false,"courseId":512399,"streamId":1,"abroadRatings":null,"discriminationFaced":null,"stayWhileStudying":null,"lowRatingMasterLabel":null,"highRatingMasterLabel":null,"foodSpending":null,"accommodationSpending":null,"transportationSpending":null,"monthlyExpenses":null,"currency":"INR","hoursSpentPreparing":null,"averageAnnualSalary":null,"anonymous":false},{"reviewId":3146757,"averageRating":2,"facultyRating":2,"campusFacilitiesRating":2,"avgSalaryPlacementRating":2,"reviewContent":{"placementDescription":"The percentage of students who got placed the previous year was around 70%. The highest and the lowest packages they received ranged between 4 Lacs to 8 Lacs per annum. Top recruiting companies that came to offer job was TCS, Wipro, Flipkart, amazon, and some others. ","infraDescription":"The facilities and infrastructure of this college for my course are not too good nor too bad but we have Wi-Fi facilities everywhere on the campus with good speed of internet connection. The quality of our mess food is so unhygienic and bad to eat in this college. ","facultyDescription":"Teachers teach well but mostly they teach from books not outside of them. Our course curriculum does not make industry ready. Our semester examination in this college is not too hard nor too easy you have to study well to score well in the examination in this college. ","reviewTitle":"Ratan's review for B.Tech in cutm.","reviewDescription":"Our events and fests at this college are quite normal and our campus life in this college is not good because they put so many restrictions. ","lowRatingReason":null,"highRatingReason":null,"knowBeforeJoining":null},"yearOfGraduation":2025,"crowdCampusRating":2,"moneyRating":2,"creationDate":"2023-06-01","firstname":"ratan singh","lastname":null,"reviewStatus":"published","helpfulCount":0,"publicMedia":[],"profilePicUrl":null,"showInstituteReply":false,"courseId":512399,"streamId":1,"abroadRatings":null,"discriminationFaced":null,"stayWhileStudying":null,"lowRatingMasterLabel":null,"highRatingMasterLabel":null,"foodSpending":null,"accommodationSpending":null,"transportationSpending":null,"monthlyExpenses":null,"currency":"INR","hoursSpentPreparing":null,"averageAnnualSalary":null,"anonymous":false},{"reviewId":3367601,"averageRating":5,"facultyRating":5,"campusFacilitiesRating":5,"avgSalaryPlacementRating":5,"reviewContent":{"placementDescription":"The percentage of students placed in our B.Tech class this year ranges between 70 to 80 percent. The highest and lowest packages offered by companies usually range between 5 Lacs to 9 Lacs respectively. Internships are only offered here in the last year of college.","infraDescription":"The facilities and infrastructure available for our B.Tech CSE course at the Bhubaneswar campus are superior to those in all other campuses. We boast high-rise buildings equipped with high-speed internet connections. Our hostels are segregated for boys and girls, and we also have a dedicated mess.","facultyDescription":"The faculty members at our Bhubaneswar campus are very friendly; they have assisted us whenever we encountered difficulties. Indeed, our course curriculum effectively prepares us for the industry. However, the semester examinations are quite challenging to pass as a minimum of 33 percent in all subjects is required to qualify.","reviewTitle":"Best college for B.Teach CSE.","reviewDescription":"Our Bhubaneswar campus is good in all things.","lowRatingReason":null,"highRatingReason":null,"knowBeforeJoining":null},"yearOfGraduation":2025,"crowdCampusRating":5,"moneyRating":5,"creationDate":"2023-12-16","firstname":"Prasad Kumar Sasmal","lastname":null,"reviewStatus":"published","helpfulCount":0,"publicMedia":[],"profilePicUrl":null,"showInstituteReply":false,"courseId":191590,"streamId":2,"abroadRatings":null,"discriminationFaced":null,"stayWhileStudying":null,"lowRatingMasterLabel":null,"highRatingMasterLabel":null,"foodSpending":null,"accommodationSpending":null,"transportationSpending":null,"monthlyExpenses":null,"currency":"INR","hoursSpentPreparing":null,"averageAnnualSalary":null,"anonymous":false},{"reviewId":3365729,"averageRating":4.2,"facultyRating":4,"campusFacilitiesRating":4,"avgSalaryPlacementRating":4,"reviewContent":{"placementDescription":"Around 60% of the students from my course were placed this year. The highest package offered was 8 lacs, and the lowest was 3 lacs, with an average of 5 lacs. The top recruiting company is Dell.\nApproximately 80% of the students got an internship. The top roles offered were website development.","infraDescription":"The facilities here are good; the infrastructure in my course/department is modern and well-equipped. The Wi-Fi coverage across the campus is excellent. The labs are well-organized with all necessary facilities. Both the classrooms and the library are spacious and of good quality. The hostel is in good condition, and the mess food, while acceptable, could be improved. The canteen here is awesome. 24*7 medical facilities are available.","facultyDescription":"The teachers here are very helpful, well-qualified, and highly knowledgeable. The course curriculum is relevant and effectively prepares the students for the industry. The semester exams are not excessively difficult to attain a good grade, resulting in a pass percentage of 90%.","reviewTitle":"Nice location\ngood placements. ","reviewDescription":"The college and campus location are good. The events and fests are really awesome. There is good connectivity, the surrounding is beautiful, but no scholarships are available here.","lowRatingReason":null,"highRatingReason":null,"knowBeforeJoining":null},"yearOfGraduation":2025,"crowdCampusRating":5,"moneyRating":4,"creationDate":"2023-12-15","firstname":"Hrishikesh Raj","lastname":null,"reviewStatus":"published","helpfulCount":0,"publicMedia":[],"profilePicUrl":null,"showInstituteReply":false,"courseId":191590,"streamId":2,"abroadRatings":null,"discriminationFaced":null,"stayWhileStudying":null,"lowRatingMasterLabel":null,"highRatingMasterLabel":null,"foodSpending":null,"accommodationSpending":null,"transportationSpending":null,"monthlyExpenses":null,"currency":"INR","hoursSpentPreparing":null,"averageAnnualSalary":null,"anonymous":false}],"pageCount":53,"pageNo":1,"reviewCount":263,"filter":{"courseIds":[],"instituteIds":[],"topicIds":[19,6,55,54,13,31,15,49,17,26,155,111,151,175,157,73,161,171,101,159,113,141,67,165,87,95,107,63,77,89],"ratingFilter":null,"basecourseIds":[],"courseInfos":null,"instituteInfos":null,"reviewIds":[3146757,3365729,3367601,3378913,3381849]},"verifiedCount":228,"unverifiedCount":35,"sorters":{"relevance":"Relevance","recency":"Recency","yearOfGraduation":"Year Of Graduation","highestRating":"Highest Rating","lowestRating":"Lowest Rating"},"sortBy":"recency","reviewSummaryDTO":{"summaries":[{"sectionName":"placements","sentiment":"positive","summaryText":"Companies like Ashok Leyland, Yamaha, TVS, Mahindra, Godrej, BEML, Triveni Turbine, Mindtree, Infotech Software, Samsung, SKH Group of Companies and many others visit the campus for placements.","basedReviewCount":56},{"sectionName":"placements","sentiment":"positive","summaryText":"Almost every student do internship either from college recommendation or with personal prefernce  Job offer usually comes as job of MR, Quality assurance, Quality controll etc.","basedReviewCount":56},{"sectionName":"placements","sentiment":"negative","summaryText":"Wipro, BPS, Mindtree, Happiest Minds, Datomato are some of the companies that hired the students.","basedReviewCount":49},{"sectionName":"placements","sentiment":"negative","summaryText":"Our senior batch also faced the same problem, and no good company visited the campus to hire them, However, the college didn't charge any money for their placements.","basedReviewCount":33},{"sectionName":"infrastructure","sentiment":"positive","summaryText":"All the labs have good equipment, classrooms are good, the library is the best place to study in the college, sports facilities are good but can be better.","basedReviewCount":148},{"sectionName":"infrastructure","sentiment":"positive","summaryText":"Hostels are well maintained, the quality of food in hostels is good, and the canteen provides very bad and unhygienic food.","basedReviewCount":78},{"sectionName":"infrastructure","sentiment":"negative","summaryText":"The canteen facility is not so good and the localities create problems for the outsiders.","basedReviewCount":19},{"sectionName":"faculty","sentiment":"positive","summaryText":"The course curriculum is designed in such a way  that it will help you in your future academic endeavors.","basedReviewCount":102},{"sectionName":"faculty","sentiment":"positive","summaryText":"Yes, the teachers inside my college are very helpful, knowledgeable, and qualified, and they teach us in a very good way.","basedReviewCount":115},{"sectionName":"faculty","sentiment":"negative","summaryText":"Some of the teachers in the college are good, but most of the teachers are not good to teach students.","basedReviewCount":28},{"sectionName":"other","sentiment":"positive","summaryText":"Everything is fine in our course, but if our college starts conducting industrial visits regularly to students, then it will be better.","basedReviewCount":53},{"sectionName":"other","sentiment":"positive","summaryText":"The university boasts many events a year-long like sports, cultural, or expo events.","basedReviewCount":43},{"sectionName":"other","sentiment":"negative","summaryText":"Our events and fests at this college are quite normal and our campus life in this college is not good because they put so many restrictions.","basedReviewCount":19}],"sectionNames":["placements","infrastructure","faculty","other"],"helpfulCount":1,"notHelpfulCount":0},"insightsDTO":{"insights":[{"sectionName":"Opportunities","context":"Internships and industry projects","insight":"Students can work with faculty on research projects","noOfResponses":77},{"sectionName":"Opportunities","context":"Internships and industry projects","insight":"Offered in the final year only","noOfResponses":77},{"sectionName":"Opportunities","context":"Employment opportunities","insight":"Many students started their own start-ups","noOfResponses":77},{"sectionName":"Opportunities","context":"Employment opportunities","insight":"Higher in core jobs","noOfResponses":77},{"sectionName":"Opportunities","context":"Higher studies preferences","insight":"Majority opted in India","noOfResponses":77},{"sectionName":"Opportunities","context":"Placement support","insight":"Students are expected to reach out to companies themselves","noOfResponses":77},{"sectionName":"Opportunities","context":"Placement support","insight":"Organized & proactive placement process","noOfResponses":77},{"sectionName":"Opportunities","context":"Alumni network","insight":"Strong alumni network that help with placement opportunities","noOfResponses":77},{"sectionName":"Opportunities","context":"Entrepreneurship cell","insight":"Very Active and resourceful, college is also involved","noOfResponses":77},{"sectionName":"Opportunities","context":"Overall feeling of students","insight":"Love being in college","noOfResponses":77},{"sectionName":"Campus Life","context":"Sports facilities","insight":"Multiple sports grounds & coaching present","noOfResponses":77},{"sectionName":"Campus Life","context":"College events","insight":"Moderately busy calendar with 1-3 monthly events","noOfResponses":77},{"sectionName":"Campus Life","context":"Mess food","insight":"Mess and Cooking arrangements are Hygienic","noOfResponses":77},{"sectionName":"Campus Life","context":"Mess food","insight":"Quality and taste of food is acceptable","noOfResponses":77},{"sectionName":"Campus Life","context":"Attendance policy","insight":"Incomplete attendance invites penalty","noOfResponses":77},{"sectionName":"Campus Life","context":"Dress code","insight":"Dress code is followed by both students and faculty","noOfResponses":77},{"sectionName":"Campus Life","context":"Additional expenses","insight":"Books","noOfResponses":77},{"sectionName":"Campus Life","context":"Additional expenses","insight":"Requirement to eat out despite mess fees","noOfResponses":77},{"sectionName":"Campus Life","context":"Additional expenses","insight":"Charges for placements and training","noOfResponses":77},{"sectionName":"Campus Life","context":"Consequence of rules violation ","insight":"Parents are called if rules are broken","noOfResponses":77},{"sectionName":"Campus Life","context":"Outside movement of girl students ","insight":"Not allowed without permission","noOfResponses":77},{"sectionName":"College Culture","context":"Locational diversity","insight":"Both from home state and outside state","noOfResponses":77},{"sectionName":"College Culture","context":"Student support services","insight":"Designated teachers/student reps are present","noOfResponses":77},{"sectionName":"College Culture","context":"Language used in campus","insight":"Mostly English is used on campus","noOfResponses":77},{"sectionName":"College Culture","context":"Language used in campus","insight":"No language challenges","noOfResponses":77},{"sectionName":"College Culture","context":"Support staff language","insight":"Not restricted to native language","noOfResponses":77},{"sectionName":"College Culture","context":"Any type of discrimination","insight":"Students don't face any discrimination","noOfResponses":77},{"sectionName":"Academic Life","context":"Frequency of exams and tests","insight":"Semester","noOfResponses":77},{"sectionName":"Academic Life","context":"Frequency of exams and tests","insight":"Monthly","noOfResponses":77},{"sectionName":"Academic Life","context":"Exam preparation","insight":"Easy to score by writing from the text book","noOfResponses":77},{"sectionName":"Academic Life","context":"Teaching methodology","insight":"Classroom teaching supplemented with Industry visits","noOfResponses":77},{"sectionName":"Academic Life","context":"Teaching methodology","insight":"Practical discussions around case studies take place often","noOfResponses":77},{"sectionName":"Academic Life","context":"Research and reading resources","insight":"Well-stocked library","noOfResponses":77},{"sectionName":"Academic Life","context":"Research and reading resources","insight":"Teachers help students with resources","noOfResponses":77},{"sectionName":"Security & Surrounding","context":"Guards and CCTV cameras","insight":"Present everywhere","noOfResponses":77},{"sectionName":"Security & Surrounding","context":"Outsiders entry","insight":"Outsiders can't enter the campus unchecked","noOfResponses":77},{"sectionName":"Security & Surrounding","context":"Outsiders entry","insight":"Outsiders don't need to take permission to move around in campus","noOfResponses":77},{"sectionName":"Security & Surrounding","context":"Security breaches","insight":"Not happened in the past","noOfResponses":77},{"sectionName":"Security & Surrounding","context":"College policy on ragging","insight":"Students can be rusticated if proved guilty","noOfResponses":77},{"sectionName":"Security & Surrounding","context":"Leaving hostel premise","insight":"Permission of authorities is required","noOfResponses":77},{"sectionName":"Security & Surrounding","context":"College accessibility","insight":"All modes of transport available from the campus","noOfResponses":77}],"sectionNames":["Opportunities","Campus Life","College Culture","Academic Life","Security & Surrounding"],"helpfulCount":0,"notHelpfulCount":0,"updatedDate":"2023-10-29 01:30:21"},"currencyCode":"INR"},"courseInfos":{"191590":{"courseId":191590,"name":"B.Tech. in Computer Science and Engineering","url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/course-b-tech-in-computer-science-and-engineering-191590"},"512399":{"courseId":512399,"name":"Bachelor of Business Administration (BBA)","url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/course-bachelor-of-business-administration-bba-512399"}},"topicNames":{"3":{"topicId":3,"topicName":"Technical Rounds","sectionName":"placements","sentimentScore":0.8372500035911798},"6":{"topicId":6,"topicName":"Recruiting Companies","sectionName":"placements","sentimentScore":0.8339650339179939},"7":{"topicId":7,"topicName":"Btech Placements","sectionNa