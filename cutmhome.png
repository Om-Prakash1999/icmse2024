939734217632},"167":{"topicId":167,"topicName":"Technical Festivals","sectionName":"other","sentimentScore":0.6787142838750567},"169":{"topicId":169,"topicName":"Practical Focus in Curriculum","sectionName":"faculty","sentimentScore":0.8141249964634577},"171":{"topicId":171,"topicName":"Knowledge Sharing","sectionName":"faculty","sentimentScore":0.7885595180449032},"175":{"topicId":175,"topicName":"Teaching Experience","sectionName":"faculty","sentimentScore":0.8232631518652564},"177":{"topicId":177,"topicName":"Separate Departments","sectionName":"infrastructure","sentimentScore":0.7871363677761771},"179":{"topicId":179,"topicName":"Extracurricular activities","sectionName":"faculty","sentimentScore":0.6847500056028366},"181":{"topicId":181,"topicName":"Student Interaction","sectionName":"faculty","sentimentScore":0.8218666652838389},"183":{"topicId":183,"topicName":"Latest Technology","sectionName":"faculty","sentimentScore":0.8698333352804184},"185":{"topicId":185,"topicName":"Course Structure","sectionName":"faculty","sentimentScore":0.7886842002994136},"187":{"topicId":187,"topicName":"Research Projects","sectionName":"faculty","sentimentScore":0.8384000062942505},"191":{"topicId":191,"topicName":"Large Campus","sectionName":"infrastructure","sentimentScore":0.87049999833107},"193":{"topicId":193,"topicName":"Cleanliness and Hygiene","sectionName":"infrastructure","sentimentScore":0.8222222212288115},"195":{"topicId":195,"topicName":"Badminton Court","sectionName":"infrastructure","sentimentScore":0.8622499853372574},"197":{"topicId":197,"topicName":"Enabled Campus","sectionName":"infrastructure","sentimentScore":0.8891250044107437},"199":{"topicId":199,"topicName":"Smart Classroom","sectionName":"faculty","sentimentScore":0.8629999955495199},"201":{"topicId":201,"topicName":"Government College","sectionName":"other","sentimentScore":0.8199999928474426},"203":{"topicId":203,"topicName":"Visiting Faculty","sectionName":"faculty","sentimentScore":0.8309999704360962},"205":{"topicId":205,"topicName":"Basketball court","sectionName":"infrastructure","sentimentScore":0.8211499929428101},"207":{"topicId":207,"topicName":"Overall Development","sectionName":"faculty","sentimentScore":0.6815999925136567}},"aggregateRatingDisplayOrder":{"avgSalaryPlacementRating":"Placements","campusFacilitiesRating":"Infrastructure","facultyRating":"Faculty & Course Curriculum","crowdCampusRating":"Crowd & Campus Life","moneyRating":"Value for Money"},"ratingInfo":{"1":"1-2","2":">2-3","3":">3-4","4":">4-5"},"pdfUrl":null,"allReviewPageUrl":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/reviews"},"isKnowledgeBoxHidden":1,"authorDetails":{"authorId":30218119,"updatedDate":"01-05-2024 15:21","createdDate":"2017-05-23T12:14:56","pageType":"institute_info","authorDisplayName":"Preety298510","authorImageUrl":null,"firstName":"Preety","lastName":"Grover","description":"Completing her PGDM course and graduating in 2020, Preety Grover is currently working at Shiksha Study Abroad as an associate senior executive in content operations. She has formerly done internships in the fields of content operation and pre-sales. Her passion lies in painting. She is a dedicated and diligent individual who gives her best at everything she does.","isAbroadAuthor":false,"twitterLink":"","facebookLink":"https://www.facebook.com/people/Priti-Grover/100008492437928/","linkedinLink":"","authorUrl":"/author/Preety298510"},"dfpParams":{"streamIds":[18,11,2,8,1,13,15,6,7,19],"baseCourseIds":[26,10,100,103,191,24,101,193,70,205,46,30,97,6,86,124,33,207]},"aboutCollegePlacement":"\n\u003cp style=\"text-align: justify;\">\u003cspan style=\"color: #e03e2d;\">\u003cstrong>What's new at Centurion University of Technology and Management Placements 2023?\u003c/strong> \u003c/span>As per the official website, the \u003cstrong>highest package\u003c/strong> offered during placements 2023 was\u003cstrong> INR 13.8 LPA\u003c/strong>. A total of \u003cstrong>1513 students\u003c/strong> out of 1684 were placed and \u003cstrong>90% placement rate\u003c/strong> was recorded during the \u003ca href=\"https://www.shiksha.com/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057\">Centurion University of Technology and Management\u003c/a> placements 2023. Above \u003cstrong>2300 multiple offers\u003c/strong> were made and \u003cstrong>more than 200 recruiters\u003c/strong> participated during placements 2023. Further, 47 students were offered a package of more than 9 LPA. The \u003cstrong>top recruiters\u003c/strong> of Centurion University of Technology and Management Bhubaneswar in 2023 were \u003cstrong>Accenture, ITC, Jio, Cipla, Justdial\u003c/strong>, etc.\u003c/p>\n\u003ctable style=\"width: 1131px;\">\u003ctbody>\u003ctr>\u003ctd style=\"width: 1113px;\">\n\u003cp>\u003cstrong>Centurion University Bhubaneswar Placements 2021:\u003c/strong>\u003c/p>\n\u003cul>\u003cli>The median package for BTech increased by nearly 9% when compared with 2020\u003c/li>\n\u003cli>A rise of almost 71% was recorded in the number of companies that participated in 2021 placements when compared with 2020\u003c/li>\n\u003c/ul>\u003c/td>\n\u003c/tr>\u003c/tbody>\u003c/table>\u003cp class=\"hiddenCMSElem dfp-tags\">DFP-Banner\u003c/p>\n\u003ch2 id=\"placement_toc_0\">\u003cstrong>Centurion University Bhubaneswar Placements Highlights 2023\u003c/strong>\u003c/h2>\n\u003ctable style=\"width: 1047px;\" border=\"1\">\u003ctbody>\u003ctr>\u003cth style=\"width: 509.631px;\">\n\u003cp>Particulars\u003c/p>\n\u003c/th>\n\u003cth style=\"width: 502.642px;\">\n\u003cp>Placement Statistics (2023)\u003c/p>\n\u003c/th>\n\u003c/tr>\u003ctr>\u003ctd style=\"width: 509.631px;\">Highest package\u003c/td>\n\u003ctd style=\"width: 502.642px;\">INR 13.8 LPA\u003c/td>\n\u003c/tr>\u003ctr>\u003ctd style=\"width: 509.631px;\">No. of interested students&nbsp;\u003c/td>\n\u003ctd style=\"width: 502.642px;\">1684\u003c/td>\n\u003c/tr>\u003ctr>\u003ctd style=\"width: 509.631px;\">No. of students placed\u003c/td>\n\u003ctd style=\"width: 502.642px;\">1513\u003c/td>\n\u003c/tr>\u003ctr>\u003ctd style=\"width: 509.631px;\">No. of multiple offers\u003c/td>\n\u003ctd style=\"width: 502.642px;\">2300+\u003c/td>\n\u003c/tr>\u003ctr>\u003ctd style=\"width: 509.631px;\">No. of recruiters\u003c/td>\n\u003ctd style=\"width: 502.642px;\">200+\u003c/td>\n\u003c/tr>\u003ctr>\u003ctd style=\"width: 509.631px;\">Placement rate\u003c/td>\n\u003ctd style=\"width: 502.642px;\">90%\u003c/td>\n\u003c/tr>\u003ctr>\u003ctd style=\"width: 509.631px;\">Popular recruiters\u003c/td>\n\u003ctd style=\"width: 502.642px;\">Cognizant, Wipro, IBM, ICICI Bank, Infosys\u003c/td>\n\u003c/tr>\u003c/tbody>\u003c/table>\u003ch2 id=\"placement_toc_1\">\u003cstrong>Centurion University Bhubaneswar Average Package 2021\u003c/strong>\u003c/h2>\n\u003cp style=\"text-align: justify;\">The Centurion University of Technology and Management Bhubaneswar average package for the 2021 drive has not been released yet. Students can have a look at the median package offered during Centurion University Bhubaneswar placements 2021 to get an estimate:\u003c/p>\n\u003ctable>\u003ctbody>\u003ctr>\u003cth colspan=\"2\" width=\"312\">\n\u003cp>\u003cstrong>Centurion University Bhubaneswar Placements 2021\u003c/strong>\u003cstrong>&nbsp;\u003c/strong>\u003c/p>\n\u003c/th>\n\u003c/tr>\u003ctr>\u003ctd style=\"width: 312px; background-color: #c2e0f4; border-style: solid; text-align: center;\" width=\"312\">\n\u003cp>\u003cstrong>Course\u003c/strong>\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 312px; background-color: #c2e0f4; border-style: solid; text-align: center;\" width=\"312\">\n\u003cp>\u003cstrong>Median Package\u003c/strong>\u003c/p>\n\u003c/td>\n\u003c/tr>\u003ctr>\u003ctd width=\"312\">\n\u003cp>\u003ca href=\"https://www.shiksha.com/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/courses/be-btech-bc\" target=\"_blank\" rel=\"noopener\">BTech\u003c/a>\u003c/p>\n\u003c/td>\n\u003ctd width=\"312\">\n\u003cp>INR 3 LPA\u003c/p>\n\u003c/td>\n\u003c/tr>\u003ctr>\u003ctd width=\"312\">\n\u003cp>\u003ca href=\"https://www.shiksha.com/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/courses/mba-pgdm-bc\" target=\"_blank\" rel=\"noopener\">MBA\u003c/a>\u003c/p>\n\u003c/td>\n\u003ctd width=\"312\">\n\u003cp>INR 3.20 LPA\u003c/p>\n\u003c/td>\n\u003c/tr>\u003c/tbody>\u003c/table>\u003ch3>\u003cstrong>Centurion University Bhubaneswar Average Package Trends\u003c/strong>\u003c/h3>\n\u003cp>The median package for BTech and MBA courses has been fluctuating over the past three years. See the below infographic showcasing the Centurion University of Technology and Management Bhubaneswar salary trends for detailed analysis:\u003c/p>\n\u003cdiv class=\"photo-widget-full\">\n\u003cdiv class=\"figure\">\n\u003cdiv class=\"photo-widget-full\">\n\u003cdiv class=\"figure\">\u003cpicture>\u003csource srcset=\"https://images.shiksha.com/mediadata/images/articles/1669726436php4n2EBO_480x360.jpeg\" media=\"(max-width: 500px)\">\u003c/source>\u003cimg src=\"https://images.shiksha.com/mediadata/images/articles/1669726436php4n2EBO.jpeg\" alt=\"Centurion University Bhubaneswar average package trends\" width=\"1280\" height=\"720\">\u003c/picture>\u003c/div>\n\u003c/div>\n\u003cp>\u003cstrong>NOTE: \u003c/strong>\u003cem>The above salary details are fetched from the NIRF report 2022.\u003c/em>\u003c/p>\n\u003c/div>\n\u003c/div>\n\u003ch2 id=\"placement_toc_2\">\u003cstrong>Centurion University Bhubaneswar Batch Placed 2021\u003c/strong>\u003c/h2>\n\u003cp>All the important highlights related to Centurion University BBSR placements 2021 are tabulated below:\u003c/p>\n\u003ctable>\u003ctbody>\u003ctr>\u003cth colspan=\"2\" width=\"623\">\n\u003cp>\u003cstrong>Centurion University Bhubaneswar Placements 2021\u003c/strong>\u003c/p>\n\u003c/th>\n\u003c/tr>\u003ctr>\u003ctd style=\"width: 312px; background-color: #c2e0f4; border-style: solid; text-align: center;\" width=\"312\">\n\u003cp>\u003cstrong>Particulars\u003c/strong>\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 312px; background-color: #c2e0f4; border-style: solid; text-align: center;\" width=\"312\">\n\u003cp>\u003cstrong>Statistics\u003c/strong>\u003c/p>\n\u003c/td>\n\u003c/tr>\u003ctr>\u003ctd width=\"312\">\n\u003cp>Job offers\u003c/p>\n\u003c/td>\n\u003ctd width=\"312\">\n\u003cp>1,102\u003c/p>\n\u003c/td>\n\u003c/tr>\u003ctr>\u003ctd width=\"312\">\n\u003cp>Companies participated\u003c/p>\n\u003c/td>\n\u003ctd width=\"312\">\n\u003cp>142\u003c/p>\n\u003c/td>\n\u003c/tr>\u003c/tbody>\u003c/table>\u003cp>\u003cstrong>NOTE:&nbsp;\u003c/strong>\u003cem>The placement statistics given on this page are the combined data for all the campuses of Centurion University.&nbsp;\u003c/em>\u003c/p>\n\u003ch3>\u003cstrong>Centurion University Bhubaneswar Batch Placed Trends\u003c/strong>\u003c/h3>\n\u003cp>A year-on-year growth was recorded in the number of offers made and the companies that participated in the past three years. See the below infographic showcasing the Centurion University placement trends:\u003c/p>\n\u003cdiv class=\"photo-widget-full\">\n\u003cdiv class=\"figure\">\n\u003cdiv class=\"photo-widget-full\">\n\u003cdiv class=\"figure\">\u003cpicture>\u003csource srcset=\"https://images.shiksha.com/mediadata/images/articles/1669726141phpYthmOE_480x360.jpeg\" media=\"(max-width: 500px)\">\u003c/source>\u003cimg src=\"https://images.shiksha.com/mediadata/images/articles/1669726141phpYthmOE.jpeg\" alt=\"Centurion University Bhubaneswar placement trends\" width=\"1280\" height=\"720\">\u003c/picture>\u003c/div>\n\u003c/div>\n\u003cp>During 2019 and 2020 placements, Management was the top stream with the highest placement rate, however, in 2022 Engineering emerged as the stop stream. The table below mentions the top streams over the past three years:\u003c/p>\n\u003c/div>\n\u003c/div>\n\u003ctable>\u003ctbody>\u003ctr>\u003cth colspan=\"4\" width=\"623\">\n\u003cp>\u003cstrong>Centurion University Bhubaneswar Placement Trends\u003c/strong>\u003c/p>\n\u003c/th>\n\u003c/tr>\u003ctr>\u003ctd style=\"width: 156px; background-color: #c2e0f4; border-style: solid; text-align: center;\" width=\"156\">\n\u003cp>\u003cstrong>Particulars\u003c/strong>\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 156px; background-color: #c2e0f4; border-style: solid; text-align: center;\" width=\"156\">\n\u003cp>\u003cstrong>2019\u003c/strong>\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 156px; background-color: #c2e0f4; border-style: solid; text-align: center;\" width=\"156\">\n\u003cp>\u003cstrong>2020\u003c/strong>\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 156px; background-color: #c2e0f4; border-style: solid; text-align: center;\" width=\"156\">\n\u003cp>\u003cstrong>2021\u003c/strong>\u003c/p>\n\u003c/td>\n\u003c/tr>\u003ctr>\u003ctd width=\"156\">\n\u003cp>Top stream\u003c/p>\n\u003c/td>\n\u003ctd width=\"156\">\n\u003cp>Management\u003c/p>\n\u003c/td>\n\u003ctd width=\"156\">\n\u003cp>Management\u003c/p>\n\u003c/td>\n\u003ctd width=\"156\">\n\u003cp>Engineering\u003c/p>\n\u003c/td>\n\u003c/tr>\u003c/tbody>\u003c/table>\u003ch2 id=\"placement_toc_3\">\u003cstrong>Centurion University Bhubaneswar Placements 2021: Stream-wise Statistics\u003c/strong>\u003c/h2>\n\u003cp>The highest placement rate recorded during Centurion University placements 2021 was for the Engineering stream. See the below infographic depicting the stream-wise placement rate for Centurion University of Technology and Management Bhubaneswar placements 2021:\u003c/p>\n\u003cdiv class=\"photo-widget-full\">\n\u003cdiv class=\"figure\">\u003cpicture>\u003csource srcset=\"https://images.shiksha.com/mediadata/images/articles/1669726195php3k7z2c_480x360.jpeg\" media=\"(max-width: 500px)\">\u003c/source>\u003cimg src=\"https://images.shiksha.com/mediadata/images/articles/1669726195php3k7z2c.jpeg\" alt=\"Centurion University Bhubaneswar placements 2021\" width=\"1280\" height=\"720\">\u003c/picture>\u003c/div>\n\u003c/div>\n\u003ch2 id=\"placement_toc_4\">Centurion University Bhubaneswar Recruiting Companies 2021\u003c/h2>\n\u003cp>Some of the eminent companies that were part of Centurion University placements 2022 are mentioned in the table below:\u003c/p>\n\u003ctable width=\"0\">\u003ctbody>\u003ctr>\u003cth colspan=\"3\" width=\"658\">\n\u003cp>\u003cstrong>Centurion University Bhubaneswar Placements 2022: Top Recruiters\u003c/strong>\u003c/p>\n\u003c/th>\n\u003c/tr>\u003ctr>\u003ctd style=\"background-color: #bfedd2; border-style: solid;\" width=\"209\">\n\u003cp>Accolite, Inc.\u003c/p>\n\u003c/td>\n\u003ctd style=\"background-color: #bfedd2; border-style: solid;\" width=\"216\">\n\u003cp>PlanetSpark\u003c/p>\n\u003c/td>\n\u003ctd style=\"background-color: #bfedd2; border-style: solid;\" width=\"232\">\n\u003cp>HCL Technologies\u003c/p>\n\u003c/td>\n\u003c/tr>\u003ctr>\u003ctd style=\"background-color: #bfedd2; border-style: solid;\" width=\"209\">\n\u003cp>Pulsus Healthtech LLP\u003c/p>\n\u003c/td>\n\u003ctd style=\"background-color: #bfedd2; border-style: solid;\" width=\"216\">\n\u003cp>IndiaMART\u003c/p>\n\u003c/td>\n\u003ctd style=\"background-color: #bfedd2; border-style: solid;\" width=\"232\">\n\u003cp>ICICI Bank&nbsp;\u003c/p>\n\u003c/td>\n\u003c/tr>\u003ctr>\u003ctd style=\"background-color: #bfedd2; border-style: solid;\" width=\"209\">\n\u003cp>Infosys\u003c/p>\n\u003c/td>\n\u003ctd style=\"background-color: #bfedd2; border-style: solid;\" width=\"216\">\n\u003cp>Capgemini\u003c/p>\n\u003c/td>\n\u003ctd style=\"background-color: #bfedd2; border-style: solid;\" width=\"232\">\n\u003cp>ITC Ltd\u003c/p>\n\u003c/td>\n\u003c/tr>\u003ctr>\u003ctd style=\"background-color: #bfedd2; border-style: solid;\" width=\"209\">\n\u003cp>SISA Information Security\u003c/p>\n\u003c/td>\n\u003ctd style=\"background-color: #bfedd2; border-style: solid;\" width=\"216\">\n\u003cp>Concentrix\u003c/p>\n\u003c/td>\n\u003ctd style=\"background-color: #bfedd2; border-style: solid;\" width=\"232\">\n\u003cp>TATA Power\u003c/p>\n\u003c/td>\n\u003c/tr>\u003c/tbody>\u003c/table>\u003cp>\u003cstrong>\u003cspan style=\"color: #e03e2d;\">Download:\u003c/span>&nbsp;\u003c/strong>\u003ca class=\"smce-docs smce-ftype-ico pdf smce-cta-link\" data-link=\"rd8uSHrTuyEzOSGklqFoV/HgfuSNdsbGyJZerPWBsCwsLucsIJ+84Fz+LylnFSnHYriwth6vFku/LnGtSU+zcgZWsCE5IR72XjZzITM5IWH1FXTYpFu1MITESVeFCATYB4YhMTMhcpPfm6s=\">Centurion University List of Recruiters 2022\u003c/a>\u003c/p>\n\u003ch2 id=\"placement_toc_5\">\u003cstrong>Centurion University Bhubaneswar Placement Brochure 2021\u003c/strong>\u003c/h2>\n\u003cp>The University has released the 2020-21 annual report, which incorporates the Centurion University Bhubaneswar placement details for the 2021 drive. The NIRF report 2022 is also out. Refer to the below table to download the reports:\u003c/p>\n\u003ctable>\u003ctbody>\u003ctr>\u003ctd style=\"background-color: #fbeeb8; border-style: dashed;\" width=\"241\">\n\u003cp>\u003ca class=\"smce-docs smce-ftype-ico pdf smce-cta-link\" data-link=\"rd8uSHrTuyEzOSGklqFoV/HgfuSNdsbGyJZerPWBsCwsLucsIJ+84Fz+LylnFSnHYriwth6vFku/LnGtSU+zcgZWsLb4QbVadT0XmgLdVdbTgl1TKfAwliEzNCFUQQeGITEzIXKT35ur\">Centurion University Annual Report 2020-21\u003c/a>\u003c/p>\n\u003c/td>\n\u003ctd style=\"background-color: #fbeeb8; border-style: dashed;\" width=\"191\">\n\u003cp>\u003ca class=\"smce-docs smce-ftype-ico pdf smce-cta-link\" data-link=\"rd8uSHrTuyEzOSGklqFoV/HgfuSNdsbGyJZerPWBsCwsLucsIJ+84Fz+LylnFSnHYriwth6vFku/LnGtSU+zcgZWsOkjzdpJl37dGm/Wlk7E1t9XWTZl0G2/9AeGITEzIXKT35ur\">Centurion University NIRF Report 2022 (Engineering)\u003c/a>\u003c/p>\n\u003c/td>\n\u003ctd style=\"background-color: #fbeeb8; border-style: dashed;\" width=\"191\">\n\u003cp>\u003ca class=\"smce-docs smce-ftype-ico pdf smce-cta-link\" data-link=\"rd8uSHrTuyEzOSGklqFoV/HgfuSNdsbGyJZerPWBsCwsLucsIJ+84Fz+LylnFSnHYriwth6