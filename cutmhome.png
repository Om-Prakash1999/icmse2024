:0,"rankingString":null,"rankingUrl":null,"url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/courses/certificate-bc","reviewUrl":null,"courseId":512481,"shortNameAbbOrFullName":"Centurion University Bhubaneswar","showInFeesAndEligibilityTable":true,"applicationLinkData":null,"feeDetailUrl":"https://images.shiksha.com/mediadata/instituteCtaPdf/feeDetails_53057_193_1704308406.pdf?v=1704322353","isRMCEnabled":0,"scholarshipsCount":0,"intakeDates":[],"instituteGrade":null,"workExpString":null,"averageMoneyRating":0,"ownership":"private","currencyConversionFactorMap":null},{"minDurationUnit":"years","minDuration":2,"maxDurationUnit":"years","maxDuration":2,"id":70,"name":"D.Pharma","exams":[{"id":13658,"name":"CUEE","url":"/engineering/cuee-exam","scope":"national"}],"examIdScores":[{"id":13658,"minScore":null,"maxScore":null}],"totalExamsCount":0,"courseRating":0,"ratingCount":0,"totalSeats":60,"courseMedianSalary":null,"courseCount":1,"minFees":147000,"maxFees":147000,"minMedianSalary":0,"maxMedianSalary":0,"minEligibilityXII":0,"maxEligibilityXII":0,"minEligibilityGraduation":0,"maxEligibilityGraduation":0,"minEligibilityPostGraduation":0,"maxEligibilityPostGraduation":0,"minEligibilityX":0,"maxEligibilityX":0,"rankingString":null,"rankingUrl":null,"url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/courses/dpharma-bc","reviewUrl":null,"courseId":283063,"shortNameAbbOrFullName":"Centurion University Bhubaneswar","showInFeesAndEligibilityTable":true,"applicationLinkData":null,"feeDetailUrl":"https://images.shiksha.com/mediadata/instituteCtaPdf/feeDetails_53057_70_1704308406.pdf?v=1704322385","isRMCEnabled":0,"scholarshipsCount":0,"intakeDates":[],"instituteGrade":null,"workExpString":null,"averageMoneyRating":0,"ownership":"private","currencyConversionFactorMap":null},{"minDurationUnit":"years","minDuration":3,"maxDurationUnit":"years","maxDuration":3,"id":205,"name":"After 10th Diploma","exams":[{"id":13658,"name":"CUEE","url":"/engineering/cuee-exam","scope":"national"}],"examIdScores":[{"id":13658,"minScore":null,"maxScore":null}],"totalExamsCount":0,"courseRating":4.1142855,"ratingCount":7,"totalSeats":0,"courseMedianSalary":null,"courseCount":8,"minFees":189000,"maxFees":189000,"minMedianSalary":0,"maxMedianSalary":0,"minEligibilityXII":0,"maxEligibilityXII":0,"minEligibilityGraduation":0,"maxEligibilityGraduation":0,"minEligibilityPostGraduation":0,"maxEligibilityPostGraduation":0,"minEligibilityX":35,"maxEligibilityX":35,"rankingString":null,"rankingUrl":null,"url":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/courses/after-10th-diploma-bc","reviewUrl":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/reviews?bc=205","courseId":480881,"shortNameAbbOrFullName":"Centurion University Bhubaneswar","showInFeesAndEligibilityTable":true,"applicationLinkData":null,"feeDetailUrl":"https://images.shiksha.com/mediadata/instituteCtaPdf/feeDetails_53057_205_1704308406.pdf?v=1704322350","isRMCEnabled":0,"scholarshipsCount":0,"intakeDates":[],"instituteGrade":null,"workExpString":null,"averageMoneyRating":4.214286,"ownership":"private","currencyConversionFactorMap":null}],"odndetailsListResponse":{"odnRedAlert":null,"odnAlertList":null},"isPremiumInstitute":false,"sectionToAnaTaggedFaqDataMap":{"ovp_section_highlights":[{"anaFaqId":25943,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_highlights","questionId":7444035,"answerId":7446211,"questionText":"What is unique about Centurion University of Technology and Management, Bhubaneswar?","answerText":"*Outcome-Based Education: CUTM focuses on outcome-based education, emphasizing practical skills and industry relevance. The curriculum is designed to bridge the gap between academia and industry requirements, ensuring that students are well-prepared for their future careers. *Socially Oriented Approach: One of the distinctive features of CUTM is its commitment to social responsibility. The university actively engages in various social development initiatives and has established a dedicated social outreach programme called &quot;Gram Tarang. &quot; Through this programme, CUTM strives to empower rural communities, promote entrepreneurship, and create sustainable livelihood opportunities. *Industry Partnerships: CUTM has strong industry partnerships and collaborations. It works closely with leading companies and organizations to provide students with internships, industry projects, and exposure to real-world challenges. This helps students gain practical experience and enhances their employability. *Skill Development Centers: CUTM has Skill Development Centers that offer training programs in areas such as automotive, construction, hospitality, agriculture, healthcare, and more. These centers provide students with hands-on learning opportunities and help develop industry-specific skills.","order":0,"answerCount":3,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-is-unique-about-centurion-university-of-technology-and-management-bhubaneswar-qna-7444035"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":348205,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_highlights","questionId":7819435,"answerId":7820143,"questionText":"Is Centurion University of Technology and Management, Bhubaneswar Campus a private or government institute? ","answerText":"\u003cp>The Centurion University of Technology and Management, Bhubaneswar Campus is a private university. It is located on the Barunei hills. The university offers over 100 courses and is known for its focus on skills, entrepreneurship, and sustainable innovations. It provides a range of programs including graduate, postgraduate, doctoral, diploma, and certificate courses.&nbsp;\u003c/p>","order":1,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/is-centurion-university-of-technology-and-management-bhubaneswar-campus-a-private-or-government-institute-qna-7819435"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":348207,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_highlights","questionId":7819437,"answerId":7820147,"questionText":"What is Centurion University of Technology and Management, Bhubaneswar Campus famous for? ","answerText":"\u003cp>The Centurion University of Technology and Management in Bhubaneswar, Odisha, is famous for its unique approach to education and its commitment to skill development, entrepreneurship, and sustainable innovations. The university offers a blend of traditional, applied, and action learning to develop productive citizens. Centurion University is also known for its School of Vocational Training, which is pioneering the concept of vocational training in India.&nbsp;\u003c/p>\u003cp>&nbsp;\u003c/p>","order":2,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-is-centurion-university-of-technology-and-management-bhubaneswar-campus-famous-for-qna-7819437"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":365967,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_highlights","questionId":7444055,"answerId":7446247,"questionText":"How is the college life at Centurion University of Technology and Management, Bhubaneswar?","answerText":"Campus Environment: CUTM boasts a spacious and well-equipped campus that creates a conducive learning environment. With modern infrastructure, well-designed classrooms, libraries, and recreational spaces, the campus provides students with everything they need for their academic and extracurricular pursuits. Academic Programs: CUTM offers a diverse range of academic programs spanning various disciplines, including engineering, management, agriculture, applied sciences, and more. The curriculum is carefully designed to strike a balance between theoretical knowledge and practical skills, ensuring that students develop a strong academic foundation. Faculty and Staff: The faculty members at CUTM are highly dedicated, knowledgeable, and supportive. They play a crucial role in guiding students, conducting engaging classes, and providing mentorship. The staff members are also available to assist students with administrative and logistical matters, creating a supportive environment. Student Activities and Clubs: CUTM encourages student engagement through a wide range of clubs, student organizations, and extracurricular activities. Cultural events, sports competitions, technical competitions, and social initiatives provide students with ample opportunities for personal growth, skill development, and fostering long-lasting friendships. Industry Exposure and Internships: CUTM places a strong emphasis on industry-oriented education. The university collaborates with industries and organizations to offer internships, industrial visits, guest lectures, and workshops. These experiences provide students with practical exposure to the corporate world, bridging the gap between academia and the professional sphere. Cultural and Sports Events: Throughout the year, CUTM organizes captivating cultural and sports events, infusing the campus with a lively and vibrant atmosphere. Students can showcase their talents in music, dance, drama, and sports through competitions, festivals, and annual gatherings. These events promote camaraderie and celebrate the diverse student community. Social Initiatives and Community Service: CUTM instills a sense of social responsibility and community engagement in its students. Active participation in community service initiatives, volunteering activities, and social awareness campaigns allows students to contribute positively to society and develop a strong sense of social consciousness. ","order":3,"answerCount":3,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/how-is-the-college-life-at-centurion-university-of-technology-and-management-bhubaneswar-qna-7444055"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":365969,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_highlights","questionId":7444067,"answerId":7446437,"questionText":"What are the top courses offered at Centurion University of Technology and Management, Bhubaneswar?","answerText":"\u003cp>The top courses offered at Centurion University of Technology and Management, Bhubaneswar include:\u003cbr>Bachelor of Technology (B.Tech)\u003cbr>Bachelor of Business Administration (BBA)\u003cbr>Master of Science (M.Sc)\u003cbr>Bachelor of Science (B.Sc)\u003cbr>Master of Business Administration (MBA)\u003cbr>Ph.D.\u003cbr>Polytechnic\u003cbr>The university offers a wide range of courses at various levels, including diploma, undergraduate, postgraduate, and doctoral programs. Some of the popular courses at the undergraduate level are B.Tech, BBA, and B.Sc, while at the postgraduate level, M.Sc and MBA are preferred choices. The university also offers a Ph.D. program for those interested in pursuing research and advanced studies.\u003c/p>","order":4,"answerCount":2,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-are-the-top-courses-offered-at-centurion-university-of-technology-and-management-bhubaneswar-qna-7444067"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":1116657,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_highlights","questionId":7597573,"answerId":7597591,"questionText":"How can I get direct admission in MCA at Centurion University? ","answerText":"\u003cp>MCA Admission Criteria at Centurion University Bhubaneswar-\u003c/p>\u003cul>\u003cli>Major criteria: JEE Mains/OJEE score/rank and graduation with 50%\u003c/li>\u003cli>Course duration: 2 years full-time\u003c/li>\u003cli>Tuition fee: INR 1.9 lakh\u003c/li>\u003cli>Eligibility: Bachelor's degree in Computer Science Engineering or equivalent degree, or B.Sc./B.Com./B.A. with Mathematics at 10+2 or graduation level (with additional bridge courses)\u003c/li>\u003c/ul>","order":5,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/how-can-i-get-direct-admission-in-mca-at-centurion-university-qna-7597573"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false}],"ovp_section_infrastructure":[{"anaFaqId":960153,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_infrastructure","questionId":7597995,"answerId":7598027,"questionText":"What is the seat intake for B.Tech at Centurion University?","answerText":"\u003cp>The seat intake of BTech with various specialisation is mention below in thr table for better understanding:&nbsp;\u003c/p>\u003ctable border=\"1\" width=\"0\" cellspacing=\"0\" cellpadding=\"0\">\u003ctbody>\u003ctr>\u003cth valign=\"top\" width=\"336\">BTech Course\u003c/th>\u003cth valign=\"top\" width=\"144\">Seat Intake\u003c/th>\u003c/tr>\u003ctr>\u003ctd valign=\"top\" width=\"336\">BTech in Computer Science and Engineering\u003c/td>\u003ctd valign=\"top\" width=\"144\">60\u003c/td>\u003c/tr>\u003ctr>\u003ctd valign=\"top\" width=\"336\">BTech in Aerospace Engineering\u003c/td>\u003ctd valign=\"top\" width=\"144\">-\u003c/td>\u003c/tr>\u003ctr>\u003ctd valign=\"top\" width=\"336\">BTech in Biotechnology Engineering\u003c/td>\u003ctd valign=\"top\" width=\"144\">-\u003c/td>\u003c/tr>\u003ctr>\u003ctd valign=\"top\" width=\"336\">BTech in Mechanical Engineering\u003c/td>\u003ctd valign=\"top\" width=\"144\">60\u003c/td>\u003c/tr>\u003ctr>\u003ctd valign=\"top\" width=\"336\">BTech in Civil Engineering\u003c/td>\u003ctd valign=\"top\" width=\"144\">60\u003c/td>\u003c/tr>\u003ctr>\u003ctd valign=\"top\" width=\"336\">BTech in Electrical and Electronic Engineering\u003c/td>\u003ctd valign=\"top\" width=\"144\">60\u003c/td>\u003c/tr>\u003ctr>\u003ctd valign=\"top\" width=\"336\">BTech in Mining Engineering\u003c/td>\u003ctd valign=\"top\" width=\"144\">-\u003c/td>\u003c/tr>\u003ctr>\u003ctd valign=\"top\" width=\"336\">BTech in Electronics and Communication Engineering&nbsp;\u003c/td>\u003ctd valign=\"top\" width=\"144\">60\u003c/td>\u003c/tr>\u003c/tbody>\u003c/table>\u003cp>&nbsp;\u003c/p>","order":1,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-is-the-seat-intake-for-b-tech-at-centurion-university-qna-7597995"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false}],"ovp_section_fAQs":[{"anaFaqId":25947,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7444033,"answerId":7446209,"questionText":"How is CGPA calculated in Centurion University of Technology and Management, Bhubaneswar?","answerText":"The calculation of CGPA (Cumulative Grade Point Average) is based on the grades obtained in the semester exams for individual subjects. The gradesheet for the semester exam results includes both SGPA (Semester Grade Point Average) and CGPA. \n\nSGPA represents the average grade points earned in a particular semester. It is calculated by dividing the total grade points obtained in all subjects during the semester by the total number of credits assigned to those subjects.\n\nCGPA, on the other hand, represents the overall average grade points earned by a student across multiple semesters. It is calculated by dividing the total grade points obtained in all semesters by the total number of credits completed in those semesters.\n\nThe gradesheet provides a comprehensive overview of the performance in each semester, as reflected by the SGPA, and the cumulative performance throughout the academic program, as indicated by the CGPA. These indicators help students and academic institutions evaluate and track academic progress accurately.","order":0,"answerCount":4,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/how-is-cgpa-calculated-in-centurion-university-of-technology-and-management-bhubaneswar-qna-7444033"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":25949,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7444051,"answerId":7446389,"questionText":"What PGs and hostels are available close to Centurion University of Technology and Management, Bhubaneswar?","answerText":"Yes, PGs and hostels are available in Centurion University. Centurion University have different hostels :- AC Hostels, Non-AC hostels. And also there Non-AC with attached bathroom. And these hostels prices are also different. ","order":1,"answerCount":3,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-pgs-and-hostels-are-available-close-to-centurion-university-of-technology-and-management-bhubaneswar-qna-7444051"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":25953,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7444057,"answerId":7446407,"questionText":"Can I get direct admission to Centurion University of Technology and Management, Bhubaneswar?","answerText":"Admissions are purely merit based and will be provided based on the students performance in the entrance exams.Like Btech admission Centurion University need twelve result or diploma result performence.\nOther branches have other types of performances","order":2,"answerCount":2,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/can-i-get-direct-admission-to-centurion-university-of-technology-and-management-bhubaneswar-qna-7444057"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":25955,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7444059,"answerId":7446415,"questionText":"What is the dress code at Centurion University of Technology and Management, Bhubaneswar?","answerText":"Students have to wear proper formal dress code and we have different dress for different courses in our university.You cannot get college dresses from outside since colleges manufacture them and charge for them.","order":3,"answerCount":2,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-is-the-dress-code-at-centurion-university-of-technology-and-management-bhubaneswar-qna-7444059"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":25957,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7444061,"answerId":7446429,"questionText":"What are some helpful tips for students starting their first year at Centurion University of Technology and Management, Bhubaneswar?","answerText":"Make a proper notes. Follow what teacher says. Make a disciplined, timetable. ","order":4,"answerCount":2,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-are-some-helpful-tips-for-students-starting-their-first-year-at-centurion-university-of-technology-and-management-qna-7444061"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":25959,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7444065,"answerId":7444261,"questionText":"Does Centurion University of Technology and Management, Bhubaneswar have international collaborations or MoUs?","answerText":"Yes, Centurion University of Technology and Management (CUTM), Bhubaneswar, has actively pursued collaborations and Memorandums of Understanding (MoUs) with international institutions and organizations. These collaborations aim to foster academic exchanges, research collaborations, and international exposure for students and faculty members. While specific collaborations may vary over time, here are some examples of international collaborations and MoUs that CUTM has had in the past:\n\n1. International Collaborations: CUTM has collaborated with renowned international universities and organizations to promote academic cooperation and exchange programs. These collaborations may include student exchange programs, faculty exchange programs, joint research projects, and sharing of academic resources.\n\n2. Skill Development Partnerships: CUTM has partnered with international institutions and organizations to enhance skill development initiatives. These collaborations focus on sharing best practices, curriculum development, and training programs to equip students with industry-relevant skills.\n\n3. Research Collaborations: CUTM has established research collaborations with international institutions to foster joint research projects, knowledge exchange, and technological advancements. These collaborations often involve faculty members and researchers from both institutions working together on specific research areas of mutual interest.\n\n4. Study Abroad Programs: CUTM may have agreements with international universities to offer study abroad programs for its students. These programs allow students to spend a semester or a year studying at partner universities, gaining international exposure and broadening their educational experience.\n\n5. Industry Collaborations: CUTM may have partnerships with international industries or organizations to promote industry-academia collaboration. These collaborations facilitate internships, industry visits, guest lectures, and industry-driven projects, providing students with practical exposure and industry insights.\n\nIt's important to note that collaborations and MoUs can evolve over time, and new partnerships may be established while existing ones may change or conclude. Therefore, I recommend visiting the official website of Centurion University of Technology and Management or contacting the university directly to get the most accurate and up-to-date information on the current international collaborations and MoUs in place. The university's international affairs office or academic department can provide detailed information on the specific collaborations and opportunities available to students.","order":5,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/does-centurion-university-of-technology-and-management-bhubaneswar-have-international-collaborations-or-mous-qna-7444065"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":25963,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7444073,"answerId":7446859,"questionText":"How are the faculty members at the Centurion University of Technology and Management, Bhubaneswar?","answerText":"A CUTM faculty member is typically well-qualified and holds relevant academic degrees. They are extremely helpful too.","order":6,"answerCount":2,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/how-are-the-faculty-members-at-the-centurion-university-of-technology-and-management-bhubaneswar-qna-7444073"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":34433,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7455565,"answerId":7456491,"questionText":"Are there any seat reservations at Centurion University of Technology and Management, Bhubaneswar Campus?","answerText":"Yes, you can get a seat reserved at Centurion University of technology and management. Students Can pay some amount of the confirm their seat.","order":7,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/are-there-any-seat-reservations-at-centurion-university-of-technology-and-management-bhubaneswar-campus-qna-7455565"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":34435,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7455445,"answerId":7457093,"questionText":"What is the student strength in Centurion University of Technology and Management, Andhra Pradesh?","answerText":"The student strength in Centurion University of Technology and Management, Andhra Pradesh is as followed as in first-year total student intake in the year 2022 was 1.05k, with a male-to-female ratio of 6:4, I. e. 60% male and 40% female.","order":8,"answerCount":2,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-is-the-student-strength-in-centurion-university-of-technology-and-management-andhra-pradesh-qna-7455445"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":34437,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7456043,"answerId":7456561,"questionText":"What happens if a student fails internal exams in Centurion University of Technology and Management, Bhubaneswar Campus?","answerText":"If a student fails internal exams in Centurion University of Technology and Management, Bhubaneswar Campus they could apply for the EOD with a fine if they do not pass an internal test. Then, once again you can give the test next semester.","order":9,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-happens-if-a-student-fails-internal-exams-in-centurion-university-of-technology-and-management-bhubaneswar-qna-7456043"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":34439,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7456047,"answerId":7457027,"questionText":"What will happen if someone misses the internal exam in Centurion University of Technology and Management, Bhubaneswar campus?","answerText":"If a student's absent from an internal test, for example because of health problems. He will be allowed to retake the exam, but they must provide reliable documentation of their absence. The student shall be approved by both the Head of Department and the class coordinator. Most re-exams take place during study breaks at the end of the semester, so if you applied for a re-exam, you need to be ready. ","order":10,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-will-happen-if-someone-misses-the-internal-exam-in-centurion-university-of-technology-and-management-bhubaneswar-qna-7456047"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":34441,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7456049,"answerId":7456599,"questionText":"How is mess food at Centurion University of Technology and Management, Bhubhneshwar campus?","answerText":"Mess food at Centurion University of Technology and Management serves breakfast, lunch, evening tea and dinner every day and the weekly menu is available with the mess in-charge. The food served is of high quality and meets the nutritional quality standards.","order":11,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/how-is-mess-food-at-centurion-university-of-technology-and-management-bhubhneshwar-campus-qna-7456049"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":34443,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7456051,"answerId":7456703,"questionText":"Does Centurion University of Technology and Management, Bhubaneswar offer hostel facilities?","answerText":"The University of Centurion has a number of accommodation, including AC and non AC dormitory rooms with attached bathrooms. There's a difference in these hotel charges.  Both male and female can get a good accommodation with all amenities.","order":12,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/does-centurion-university-of-technology-and-management-bhubaneswar-offer-hostel-facilities-qna-7456051"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":34445,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7456053,"answerId":7456813,"questionText":"What specialisation does Centurion University of Technology and Management, Bhubaneswar offer in their Medical courses?","answerText":"Fields in which Centurion University of Technology and Management, Bhubaneswar provide specialization in Medical courses are Optometry, Medical Laboratory Technician, Radiation Technology, Physiotherapy, Anesthesia, Clinical Microbiology.","order":13,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-specialisation-does-centurion-university-of-technology-and-management-bhubaneswar-offer-in-their-medical-qna-7456053"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":365971,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7819433,"answerId":7820141,"questionText":"Is Centurion University of Technology and Management, Bhubaneswar Campus as good as C. V. Raman Global University? ","answerText":"\u003cp>Both Centurion University of Technology and Management, Bhubaneswar Campus and C. V. Raman Global University are reputed institutions in Bhubaneswar, Odisha, India. Centurion University of Technology and Management has been recognized as a Center of Excellence by the Ministry of Skill Development and Entrepreneurship, Government of India. On the other hand, C. V. Raman Global University is also a well-regarded institution. It has been ranked 101 for Overall by NIRF in 2023. In conclusion, both universities have their strengths and areas for improvement. The choice between the two would depend on your personal preferences and academic goals.\u003c/p>","order":14,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/is-centurion-university-of-technology-and-management-bhubaneswar-campus-as-good-as-c-v-raman-global-university-qna-7819433"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":1095387,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":8869607,"answerId":8869609,"questionText":"How is the overall infrastructure of Centurion University Bhubaneswar? ","answerText":" [Source: B.Pharma students & alumni]. Based on the reviews, the overall infrastructure of Centurion University Bhubaneswar is well-maintained and provides adequate facilities for its students. Reviewers have praised the university's infrastructure, including its well-built and maintained buildings, hostels with Wi-Fi and other amenities and fully equipped laboratories. Some reviewers have noted that the university's library is stocked with a wide range of books relevant to the courses offered. Additionally, the university offers free skill courses alongside its main courses, providing students with opportunities to develop their skills beyond their academic studies.\u003cbr />\u003cbr />\u003cb>Summary:\u003c/b> Centurion University Bhubaneswar has a well-maintained infrastructure with modern facilities such as hostels, libraries, laboratories and sports facilities. The university offers a range of programs and provides students with access to a diverse range of resources and opportunities to develop their skills.\u003cbr />\u003cbr />Above answer is based on below reviews\u003cbr />Well build and maintained infr . by \u003ca href='https://www.shiksha.com/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/reviews? reviewId=3255821'>Pankaj\u003c/a>\u003cbr />Class rooms are quite good for . by \u003ca href='https://www.shiksha.com/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/reviews? reviewId=3190119'>Sukarna\u003c/a>\u003cbr />The classrooms and labs are ve . by \u003ca href='https://www.shiksha.com/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/reviews? reviewId=2038371'>Ashirbad\u003c/a>\u003cbr />There is no doubt that no one . by \u003ca href='https://www.shiksha.com/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/reviews? reviewId=1907227'>Anshuman\u003c/a>\u003cbr />All the facilities are availab . by \u003ca href='https://www.shiksha.com/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/reviews? reviewId=1878825'>Milan\u003c/a>","order":15,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/how-is-the-overall-infrastructure-of-centurion-university-bhubaneswar-qna-8869607"},"anaFaqSource":"manual","generationSource":"ShikshaGPT","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":1116669,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fAQs","questionId":7819451,"answerId":7821135,"questionText":"Can I get into Centurion University of Technology and Management, Bhubaneswar Campus with 75% in class 12? ","answerText":"\u003cp>The Centurion University of Technology and Management (CUTM), located in Bhubaneswar, Odisha, is a pioneering institution in the field of higher education. To be eligible for the Centurion University of Technology and Management, Candidates must have earned at least a 50% grade point average in their Class 12 exams to be eligible. For SC/ST applicants, there is a 5% mark reduction, making the admissions process more accessible and inclusive.&nbsp;\u003c/p>","order":16,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/can-i-get-into-centurion-university-of-technology-and-management-bhubaneswar-campus-with-75-in-class-12-qna-7819451"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false}],"ovp_section_notable_alumni":[{"anaFaqId":960161,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_notable_alumni","questionId":7597913,"answerId":7597939,"questionText":"Can I get direct admission in Centurion University BTech? ","answerText":"\u003cp>The admission process in Centurion University Bhubaneswar for BTech course is mentioned below:\u003c/p>\u003cul>\u003cli>Register for CUEE 2023 and pay the application fee of INR 600.\u003c/li>\u003cli>Appear for the CUEE exam either online or at a notified test center.\u003c/li>\u003cli>If you qualify the exam, you will be eligible for provisional admission.\u003c/li>\u003cli>Pay the minimum fee and submit the original documents for verification.\u003c/li>\u003cli>Report to the campus on the notified date.\u003c/li>\u003c/ul>\u003cp>Here are some additional details:\u003c/p>\u003cul>\u003cli>The CUEE exam is conducted in online mode\u003c/li>\u003cli>The application fee can be paid online or through demand draft\u003c/li>\u003cli>Pay the minimum fee for provisional admission&nbsp;\u003c/li>\u003cli>The original documents that need to be submitted for verification include:&nbsp;Qualifying mark sheet, Certificate/rank/score card, &nbsp;Aadhar card, &nbsp;PAN card, &nbsp;Payment receipt, &nbsp;Passport-sized photographs\u003c/li>\u003cli>The notified date for reporting to the campus will be mentioned in the provisional admission letter.\u003c/li>\u003c/ul>","order":1,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/can-i-get-direct-admission-in-centurion-university-btech-qna-7597913"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":1116661,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_notable_alumni","questionId":7598269,"answerId":7598279,"questionText":"What is the last date to apply for the BBA in Centurion University Bhubaneswar? ","answerText":"\u003cp>The last date of applying CUEE for BBA in Centurion University BBSR is \u003cstrong>25th Aug 2023\u003c/strong>.&nbsp;The exam will be on every 30th of the month, starting from \u003cstrong>30th Dec 2022 &ndash; 30th Aug 2023\u003c/strong>.\u003c/p>\u003ctable border=\"1\" cellspacing=\"0\" cellpadding=\"0\">\u003ctbody>\u003ctr>\u003cth valign=\"top\" width=\"239\">\u003cstrong>DATES\u003c/strong>\u003c/th>\u003cth valign=\"top\" width=\"239\">\u003cstrong>UPCOMING EVENTS\u003c/strong>\u003c/th>\u003c/tr>\u003ctr>\u003ctd valign=\"top\" width=\"239\">30 Jun 2023\u003c/td>\u003ctd valign=\"top\" width=\"239\">BBA CUEE 2023\u003c/td>\u003c/tr>\u003ctr>\u003ctd valign=\"top\" width=\"239\">30 Jul 2023\u003c/td>\u003ctd valign=\"top\" width=\"239\">BBA CUEE 2023\u003c/td>\u003c/tr>\u003ctr>\u003ctd valign=\"top\" width=\"239\">25 Aug 2023\u003c/td>\u003ctd valign=\"top\" width=\"239\">Last date for applying CUEE 2023\u003c/td>\u003c/tr>\u003ctr>\u003ctd valign=\"top\" width=\"239\">30 Aug 2023\u003c/td>\u003ctd valign=\"top\" width=\"239\">BBA CUEE 2023\u003c/td>\u003c/tr>\u003c/tbody>\u003c/table>\u003cp>&nbsp;\u003c/p>","order":2,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-is-the-last-date-to-apply-for-the-bba-in-centurion-university-bhubaneswar-qna-7598269"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":1116663,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_notable_alumni","questionId":7580685,"answerId":7580711,"questionText":"Is Centurion University good for BTech? ","answerText":"\u003cp>The total tuition fee for the course BTech is ranging from INR 5.67 Lacs &ndash; INR 6 Lacs for four years. The fee may vary due to the different specialisation offered by the Centurion University.&nbsp; The mentioned fee has been taken from unofficial source. Hence, the data might get vary. The overall rating is 3.8 based on verified reviews, the Placements records of median salary is 3.50 lakh. The eligibility criteria for BTech course offered by the university is Class 12 (Physics, Chemistry, Math&rsquo;s) with 50% aggregate (5% relaxation for reserved category) and&nbsp;CUEE score/rank.&nbsp;\u003c/p>","order":3,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/is-centurion-university-good-for-btech-qna-7580685"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":960159,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_notable_alumni","questionId":7597987,"answerId":7597991,"questionText":"What are the courses offered by the Centurion University BTech? ","answerText":"\u003cp>Centurion University BTech course offers eight specialisation under BTech Programme which are listed&nbsp; below:\u003c/p>\u003cul>\u003cli>BTech in Computer Science and Engineering\u003c/li>\u003cli>BTech in Aerospace Engineering\u003c/li>\u003cli>BTech in Biotechnology Engineering\u003c/li>\u003cli>BTech in Mechanical Engineering\u003c/li>\u003cli>BTech in Civil Engineering\u003c/li>\u003cli>BTech in Electrical and Electronic Engineering\u003c/li>\u003cli>BTech in Mining Engineering\u003c/li>\u003cli>BTech in Electronics and Communication Engineering&nbsp;\u003c/li>\u003c/ul>","order":4,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-are-the-courses-offered-by-the-centurion-university-btech-qna-7597987"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":1035475,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_notable_alumni","questionId":7819475,"answerId":7820715,"questionText":"How are MBA placements at Centurion University of Technology and Management, Bhubaneswar Campus? ","answerText":"\u003cp>CUTM has a good placement record, with a placement rate of over 90% in recent years. The average salary package offered to students is also impressive, with the average salary package for the 2023 batch being over INR 6 LPA.\u003c/p>","order":5,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/how-are-mba-placements-at-centurion-university-of-technology-and-management-bhubaneswar-campus-qna-7819475"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false}],"ovp_section_placements":[{"anaFaqId":34449,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_placements","questionId":7456057,"answerId":7456851,"questionText":"Which are top industries that recruit from Centurion University of Technology and Management, Bhubaneswar?","answerText":"\u003cdiv>Centurion University of Technology and Management, Bhubaneswar is a reputed university that attracts recruiters from various fields.&nbsp;The University is the place where many top companies recruit talent in fields such as finance, technology, engineering, marketing and advertising, management, accounting, human resources, IT, education, start-ups, banking, retail, pharmaceuticals and hospitality.&nbsp;It functions as a platform for, infrastructure, automobiles, etc. Some of the top companies that have recruited from the university include Accenture, ITC, Jio, and Cipla.\u003c/div>\u003cp>&nbsp;\u003c/p>","order":0,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/which-are-top-industries-that-recruit-from-centurion-university-of-technology-and-management-bhubaneswar-qna-7456057"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":34451,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_placements","questionId":7456061,"answerId":7456985,"questionText":"What is the highest placement package offered to students of Centurion University of Technology and Management, Bhubaneswar Campus?","answerText":"Centurion University of Technology and Management, Bhubaneswar Campus provide nearly 80% of the students enrolled at our school. TCS is one of the largest recruitment firms in the world. The highest salary package offered is 8 LPA. The lowest remuneration package we offer is 3 LPA.","order":1,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-is-the-highest-placement-package-offered-to-students-of-centurion-university-of-technology-and-management-qna-7456061"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":348333,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_placements","questionId":7819461,"answerId":7821173,"questionText":"What is the average package offered at Centurion University of Technology and Management, Bhubaneswar Campus? ","answerText":"\u003cp>The Centurion University of Technology and Management's placements for 2023 are illustrated in the following manner:\u003c/p>\u003cp>- The maximum package available was INR 13.8 Lacs per year.\u003c/p>\u003cp>- A remarkable 1513 of the 1684 students who applied for placement did so, yielding a placement rate of 90%.\u003c/p>\u003cp>- More than 2300 job offers were sent to students, and over 200 businesses actively took part in the placements.\u003c/p>\u003cp>47 pupils received job offers with salaries surpassing 9 Lacs annually, which is noteworthy.\u003c/p>\u003cp>- In 2023, Accenture, ITC, Jio, Cipla, Justdial, and many others were among the top employers.\u003c/p>","order":2,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-is-the-average-package-offered-at-centurion-university-of-technology-and-management-bhubaneswar-campus-qna-7819461"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":348335,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_placements","questionId":7819463,"answerId":7820517,"questionText":"Does Centurion University of Technology and Management, Bhubaneswar Campus offer better placements than C. V. Raman Global University? ","answerText":"\u003cp>Both Centurion University of Technology and Management, Bhubaneswar Campus, and C. V. Raman Global University have good placement records. The Centurion University of Technology and Management offers about 90% placement with the highest package being 10 LPA and an average package of 3-4 LPA. On the other hand, at C. V. Raman Global University the highest salary package offered was 40 LPA by Amazon. In conclusion, both universities have strong placement records. However, the choice between the two should depend on your preferred course and the companies you aspire to work for.\u003c/p>","order":3,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/does-centurion-university-of-technology-and-management-bhubaneswar-campus-offer-better-placements-than-c-v-raman-qna-7819463"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":348339,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_placements","questionId":7819467,"answerId":7821177,"questionText":"Does Centurion University of Technology and Management, Bhubaneswar Campus have good placements? ","answerText":"\u003cp>Yes, the college have&nbsp;\u003cstrong>Good&nbsp;\u003c/strong>placements as we can see the records for 2023 as follows:\u003c/p>\u003cp>This In the placements at the Centurion University of Technology and Management for 2023:\u003c/p>\u003cp>- An astounding 1513 out of a total of 1684 students were placed in jobs, yielding a high placement rate of 90%.\u003c/p>\u003cp>- Surprisingly, students received over 2300 job offers, meaning that many had a variety of employment options to select from.\u003c/p>\u003cp>- More than 200 recruiters took part in the placement process, which was lively and showed off a variety of prospects for the students.\u003c/p>","order":4,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/does-centurion-university-of-technology-and-management-bhubaneswar-campus-have-good-placements-qna-7819467"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":1035471,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_placements","questionId":7598055,"answerId":7598075,"questionText":"What is the highest package of Centurion University BTech? ","answerText":"\u003cp>Centurion University Bhubaneswar has a strong placement record. In 2022, over 50% of students were placed, with the highest salary package offered being INR 5.00 LPA and the lowest salary package being INR 2.5 LPA. The placement cell works with a wide range of companies, including IT, engineering, finance, and consulting firms. In 2022, some of the top recruiters at Centurion University Bhubaneswar included: Infosys, Wipro, TCS, Amazon, Cognizant, Tech Mahindra, Capgemini, IBM, HCL.&nbsp;The most popular sectors for placements were IT, engineering, and finance.&nbsp;The top recruiters were from India, but there were also some international recruiters.\u003c/p>","order":5,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-is-the-highest-package-of-centurion-university-btech-qna-7598055"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false}],"ovp_section_admission_dates":[{"anaFaqId":354441,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_admission_dates","questionId":7580669,"answerId":7580677,"questionText":"How do I get a seat at Centurion University? ","answerText":"\u003cp>The University conducts a common Entrance Exam for the UG &amp; PG courses. The Entrance Exam dates for the academic year 2023: \u003cstrong>30th of every month\u003c/strong> starting from \u003cstrong>30th Dec 2022 to 30\u003csup>th\u003c/sup> August 2023.\u003c/strong> Last date of applying will be 25 Aug 11:59 PM with a minimum fee of INR 600. To get admission in Centurion University you need to follow the mentioned below steps:\u003c/p>\u003cp>Step 1: Apply for the entrance exam CUEE- 2023, through the official website. The mode of examination will be Online/Offline.\u003c/p>\u003cp>Step 2: The registered candidates will be informed about the exam time, link, credentials, etc. via E-mail.\u003c/p>\u003cp>Step 3: Result Declaration, Reporting for Counselling and admission.\u003c/p>\u003cp>Step 4: Documentation process\u003c/p>\u003cp>Step 5: Reporting details (date, time, schedule, etc.)\u003c/p>","order":0,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/how-do-i-get-a-seat-at-centurion-university-qna-7580669"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":354443,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_admission_dates","questionId":7580757,"answerId":7580771,"questionText":"What is the mode of application at Centurion University Bhubaneswar? ","answerText":"\u003cp>The mode of application is Online &amp; Offline as well. The Entrance Exam dates for the academic year 2023: \u003cstrong>30th of every month\u003c/strong> starting from \u003cstrong>30th Dec 2022 to 30\u003csup>th\u003c/sup> August 2023.\u003c/strong> Last date of applying will be 25 Aug 11:59 PM with a minimum fee of INR 600. The applicants can apply from the official website of the CUTM. For the applicants who are appearing for the online mode need to give proctored based test, and for the offline applicants, should report to Notified Test Centre or at the University campus. To get admission in Centurion University you need to follow the mentioned below step:\u003c/p>\u003cp>Step 1: Apply for the entrance exam CUEE- 2023, through the official website. The mode of examination will be Online/Offline.\u003c/p>\u003cp>Step2: The registered candidates will be informed about the exam time, link, credentials, etc. via E-mail.\u003c/p>\u003cp>Step 3: Result Declaration, Reporting for Counselling and admission.\u003c/p>\u003cp>Step 4: Documentation process\u003c/p>\u003cp>Step 5: Reporting details (date, time, schedule, etc.)\u003c/p>","order":1,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-is-the-mode-of-application-at-centurion-university-bhubaneswar-qna-7580757"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":354447,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_admission_dates","questionId":7580947,"answerId":7580969,"questionText":"Does Centurion University offer Diploma courses, what is the eligibility criteria? ","answerText":"\u003cp>Yes, Centurion University offers Diploma courses with various programme like School of Paramedics &amp; allied Health Science, School of Pharmacy and Life Sciences and School of Vocational Training, refer to the table for more understanding.\u003c/p>\u003ctable style=\"border-collapse: collapse; width: 100%;\" border=\"1\">\u003ccolgroup>\u003ccol style=\"width: 50%;\">\u003ccol style=\"width: 50%;\">\u003c/colgroup>\u003ctbody>\u003ctr>\u003cth>Diploma Courses\u003c/th>\u003cth>Eligibility&nbsp;\u003c/th>\u003c/tr>\u003ctr>\u003ctd>School of Paramedics &amp; allied Health Science (8 courses)\u003c/td>\u003ctd>Class 12, CUEE&nbsp;\u003c/td>\u003c/tr>\u003ctr>\u003ctd>School of Pharmacy and Life Sciences\u003c/td>\u003ctd>Class 12, CUEE&nbsp;\u003c/td>\u003c/tr>\u003ctr>\u003ctd>School of Vocational Training (13 courses)\u003c/td>\u003ctd>Class 12, CUEE&nbsp;\u003c/td>\u003c/tr>\u003c/tbody>\u003c/table>","order":2,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/does-centurion-university-offer-diploma-courses-what-is-the-eligibility-criteria-qna-7580947"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":449167,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_admission_dates","questionId":7444057,"answerId":7446407,"questionText":"Can I get direct admission to Centurion University of Technology and Management, Bhubaneswar?","answerText":"Admissions are purely merit based and will be provided based on the students performance in the entrance exams.Like Btech admission Centurion University need twelve result or diploma result performence.\nOther branches have other types of performances","order":3,"answerCount":2,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/can-i-get-direct-admission-to-centurion-university-of-technology-and-management-bhubaneswar-qna-7444057"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false}],"ovp_section_fees_and_eligibility":[{"anaFaqId":25945,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fees_and_eligibility","questionId":7444095,"answerId":7446545,"questionText":"What rank is necessary for MBA at Centurion University of Technology and Management, Bhubaneswar?","answerText":"The overall cutoff for MBA is 25 percentile. Cutoff trends of the university admission to various department vary programme wise and with each academic year and the same is privy to the office of the university. ","order":0,"answerCount":3,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-rank-is-necessary-for-mba-at-centurion-university-of-technology-and-management-bhubaneswar-qna-7444095"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":34447,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fees_and_eligibility","questionId":7456059,"answerId":7456895,"questionText":"What is hostel fees at Centurion University of Technology and Management, Bhubaneswar Campus?","answerText":"Centurion University hostel fees are :-\n A/C room with attached toilet (3 Seater): Rs. 1,25,000/-\nNon A/C room with attached toilet (4 Seater): Rs. 95,000/-\nNon A/C room with common toilet (5 Seater): Rs. 80,000/-. .","order":1,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-is-hostel-fees-at-centurion-university-of-technology-and-management-bhubaneswar-campus-qna-7456059"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":960151,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fees_and_eligibility","questionId":7597945,"answerId":7597961,"questionText":"What is fee for BTech at Centurion University? ","answerText":"\u003cp>BTech at Centurion University is of four year course for full time, the CUTM offers eight Specialisation in BTech. The variation in fee depends on the specialsation provided by the University.&nbsp;\u003c/p>\u003ctable border=\"1\" cellspacing=\"0\" cellpadding=\"0\">\u003ctbody>\u003ctr>\u003cth valign=\"top\" width=\"312\">\u003cstrong>Parameters\u003c/strong>\u003c/th>\u003cth valign=\"top\" width=\"312\">\u003cstrong>Details\u003c/strong>\u003c/th>\u003c/tr>\u003ctr>\u003ctd valign=\"top\" width=\"312\">Course\u003c/td>\u003ctd valign=\"top\" width=\"312\">BTech\u003c/td>\u003c/tr>\u003ctr>\u003ctd valign=\"top\" width=\"312\">Eligibility\u003c/td>\u003ctd valign=\"top\" width=\"312\">CUEE, JEE Mains\u003c/td>\u003c/tr>\u003ctr>\u003ctd valign=\"top\" width=\"312\">Total Tuition Fee\u003c/td>\u003ctd valign=\"top\" width=\"312\">INR 5.67 Lacs - INR 6.00 Lakh\u003c/td>\u003c/tr>\u003c/tbody>\u003c/table>\u003cp>&nbsp;\u003c/p>","order":2,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-is-fee-for-btech-at-centurion-university-qna-7597945"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":1116659,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fees_and_eligibility","questionId":7819455,"answerId":7821145,"questionText":"How can I check my merit list at Centurion University of Technology and Management, Bhubaneswar Campus? ","answerText":"\u003cp>The Centurion University of Technology and Management (CUTM), located in Bhubaneswar, Odisha, is a pioneering institution in the field of higher education. You can visit the official website of Centurion University of Technology and Management to check your merit list. A formal Admission Letter informing each candidate of their successful selection and merit will be sent to their registered email address after they have been chosen.&nbsp;\u003c/p>","order":3,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/how-can-i-check-my-merit-list-at-centurion-university-of-technology-and-management-bhubaneswar-campus-qna-7819455"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":960147,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_fees_and_eligibility","questionId":7819479,"answerId":7820699,"questionText":"What is the fee for MBA at Centurion University of Technology and Management, Bhubaneswar Campus? ","answerText":"\u003cp>The tuition fee for MBA at Centurion University of Technology and Management, Bhubaneswar Campus is ?2.10 Lacs for the first year. The total tuition fee for the two-year programme is ?4.20 lakhs.\u003c/p>","order":4,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-is-the-fee-for-mba-at-centurion-university-of-technology-and-management-bhubaneswar-campus-qna-7819479"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false}],"ovp_section_affiliated_colleges/departments":[{"anaFaqId":1116665,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_affiliated_colleges/departments","questionId":7819469,"answerId":7820707,"questionText":"How many recruiters participated in Centurion University of Technology and Management, Bhubaneswar Campus placements? ","answerText":"\u003cp>According to the Centurion University of Technology and Management (CUTM) website, more than 200 recruiters participated in the Bhubaneswar campus placements in 2023. Some of the top recruiters included Accenture, ITC, Jio, Cipla, and Justdial.\u003c/p>","order":1,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/how-many-recruiters-participated-in-centurion-university-of-technology-and-management-bhubaneswar-campus-placements-qna-7819469"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":1116667,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_affiliated_colleges/departments","questionId":7819473,"answerId":7821185,"questionText":"What entrance exam scores do Centurion University of Technology and Management, Bhubaneswar Campus accept for admission to MBA? ","answerText":"\u003cp>The Centurion University of Technology and Management, Bhubaneswar Campus, conducts its own entrance examination known as CUEE for admission to all its courses. However, for the MBA program, students who have qualified in national-level examinations like CAT, XAT, MAT, or CET are exempted from the CUEE. A bachelor's degree in any subject with a score of 50%, including the arts, sciences, commerce, or engineering, is mandatory for admission.&nbsp;\u003c/p>","order":2,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-entrance-exam-scores-do-centurion-university-of-technology-and-management-bhubaneswar-campus-accept-for-admission-qna-7819473"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":960165,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_affiliated_colleges/departments","questionId":7819477,"answerId":7820711,"questionText":"How many students can do an MBA at Centurion University of Technology and Management, Bhubaneswar Campus?","answerText":"\u003cp>Centurion University of Technology and Management, Bhubaneswar Campus has an intake of 60 students for the MBA program.\u003c/p>","order":3,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/how-many-students-can-do-an-mba-at-centurion-university-of-technology-and-management-bhubaneswar-campus-qna-7819477"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":960167,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_affiliated_colleges/departments","questionId":7819459,"answerId":7821159,"questionText":"Can I get Centurion University of Technology and Management, Bhubaneswar Campus with 500 rank in JEE? ","answerText":"\u003cp>It is straightforward to apply to Centurion University:\u003c/p>\u003cp>1. Your CUEE score and a personal interview are required for admission to the majority of courses.\u003c/p>\u003cp>They also take JEE Main scores into account if you're applying to a BTech degree. For BTech, you need a CUEE or JEE Main rank within 50,000 or within 3 lakh.\u003c/p>\u003cp>3. Using the names of the chosen students, the university compiles a merit list. There you go!\u003c/p>","order":4,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/can-i-get-centurion-university-of-technology-and-management-bhubaneswar-campus-with-500-rank-in-jee-qna-7819459"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":960169,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_affiliated_colleges/departments","questionId":7819457,"answerId":7820701,"questionText":"Is OJEE required for MBA at Centurion University of Technology and Management, Bhubaneswar Campus? ","answerText":"\u003cp>No, OJEE is not required for MBA at Centurion University of Technology and Management, Bhubaneswar Campus. The eligibility criteria for the MBA program at CUTM is the completion of the degree in any discipline with passing marks. It is a private university located in Bhubaneswar, India. It offers a wide range of courses across various disciplines including MBA, Engineering, Vocational studies and etc.&nbsp;\u003c/p>","order":5,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/is-ojee-required-for-mba-at-centurion-university-of-technology-and-management-bhubaneswar-campus-qna-7819457"},"anaFaqSource":"asq","generationSource":"manual","level":0,"parentQuesId":0,"animated":false}],"ovp_section_popular_courses":[{"anaFaqId":348259,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_popular_courses","questionId":7819441,"answerId":7820155,"questionText":"What is the fee for various courses offered by Centurion University of Technology and Management, Bhubaneswar Campus? ","answerText":"\u003cp>The fee for various courses offered by Centurion University of Technology and Management, Bhubaneswar Campus:&nbsp;\u003c/p>\u003cp>BBA: Rs 66,000 per year\u003c/p>\u003cp>B.Tech: Rs 1.42 Lacs per year\u003c/p>\u003cp>M.Sc: Rs 80,000 per year\u003c/p>\u003cp>MBA: Rs 7.5 Lacs per year\u003c/p>\u003cp>M.Tech: Rs 78,750 per year\u003c/p>\u003cp>Polytechnic: Rs 52,500 per year\u003c/p>\u003cp>BA: Rs 1,05,000\u003c/p>\u003cp>Diploma in engineering: Rs 1,53,750\u003c/p>\u003cp>BCA: Rs 70,000 per year\u003c/p>","order":0,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-is-the-fee-for-various-courses-offered-by-centurion-university-of-technology-and-management-bhubaneswar-campus-qna-7819441"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":348261,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_popular_courses","questionId":7819443,"answerId":7820161,"questionText":"What are the courses offered at Centurion University of Technology and Management, Bhubaneswar Campus? ","answerText":"\u003cp>Centurion University of Technology and Management, Bhubaneswar offers a wide range of courses across various disciplines. Some of the courses available at the Bhubaneswar campus include BBA, B.Tech, M.Sc, MBA, M.Tech, Polytechnic, BA, Diploma in Engineering, BCA, commerce, pharmacy, agriculture management, medical, paramedical and computer applications.&nbsp;\u003c/p>","order":1,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/what-are-the-courses-offered-at-centurion-university-of-technology-and-management-bhubaneswar-campus-qna-7819443"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":348263,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_popular_courses","questionId":7819445,"answerId":7820165,"questionText":"Is Centurion University of Technology and Management, Bhubaneswar Campus good for engineering? ","answerText":"\u003cdiv>Centurion University of Technology and Management, Bhubaneswar is a reputed educational institution offering a wide range of engineering courses. It is&nbsp;highly regarded for its&nbsp;engineering programs and industry collaborations.&nbsp;The university's hands-on approach to learning, strong links with industry and commitment to skills development make it a preferred choice for engineering aspirants.&nbsp;\u003c/div>","order":2,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/is-centurion-university-of-technology-and-management-bhubaneswar-campus-good-for-engineering-qna-7819445"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false},{"anaFaqId":348265,"entityId":53057,"entityType":"institutePage","childPage":"overviewPage","wikiIdentifier":"ovp_section_popular_courses","questionId":7819447,"answerId":7820169,"questionText":"Which is the top course at Centurion University of Technology and Management, Bhubaneswar Campus? ","answerText":"\u003cdiv>Centurion University of Technology and Management, Bhubaneswar is a reputed educational institution offering a wide range of courses. The university is a top MBA college in Bhubaneshwar, Odisha. The national ranking framework ranked Centurion University Technology and Management number one for MBA. Some Popular courses from the university include B.Tech, MBBS, ME/M. Tech, B.Sc, BA, B.Com, etc.\u003c/div>","order":3,"answerCount":1,"url":{"url":null,"urlHost":null,"absoluteUrl":"https://ask.shiksha.com/which-is-the-top-course-at-centurion-university-of-technology-and-management-bhubaneswar-campus-qna-7819447"},"anaFaqSource":"manual","generationSource":"manual","level":0,"parentQuesId":0,"animated":false}]},"instituteSectionData":{"ovp_section_highlights":{"description":"\u003cp>Established in 2005, Centurion University of Technology and Management (CUTM) is a multi-sector, private university located in Odisha, India. Accredited with NAAC with &lsquo;A&rsquo; grade, the main campus of CUTM is located at Paralakhemundi (Gajapati district). Centurion University has other campuses located in \u003cstrong>Bhubaneswar\u003c/strong> and Visakhapatnam (or Vizianagaram) along with three regional campuses located in Rayagarh, Balangir (or Bolangir) and Balasore.\u003c/p>\n\u003cp>Spread over 40 acres of land in the foothill of Barunei hills, near Jatni town, the Bhubaneswar campus of Centurion University of Technology and Management (CUTM) is located adjacent to NISER, IIT, AIIMS and Xavier University. Centurion University Bhubaneswar offers over 90+ courses across various fields such as Engineering, Management, Science, Mass Communication and Media, Design, Hotel Management and Pharmacy among various others. Mentioned below are a few highlights around Centurion University Bhubaneswar:\u003c/p>\n\u003ctable style=\"width: 1135px; height: 223px;\">\n\u003ctbody>\n\u003ctr style=\"height: 29px;\">\n\u003cth style=\"width: 530.469px; height: 29px;\">\n\u003cp>Particulars\u003c/p>\n\u003c/th>\n\u003cth style=\"width: 569.531px; height: 29px;\">\n\u003cp>Statistics\u003c/p>\n\u003c/th>\n\u003c/tr>\n\u003ctr style=\"height: 29px;\">\n\u003ctd style=\"width: 530.469px; height: 29px;\">\n\u003cp>Year of establishment\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 569.531px; height: 29px;\">\n\u003cp>2005 (main campus)\u003c/p>\n\u003c/td>\n\u003c/tr>\n\u003ctr style=\"height: 29px;\">\n\u003ctd style=\"width: 530.469px; height: 29px;\">\n\u003cp>Total campuses\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 569.531px; height: 29px;\">\n\u003cp>6 (Paralakhemundi, Visakhapatnam, Bhubaneswar, Balangir, Rayagarh and Balasore )\u003c/p>\n\u003c/td>\n\u003c/tr>\n\u003ctr style=\"height: 29px;\">\n\u003ctd style=\"width: 530.469px; height: 29px;\">\n\u003cp>Recognised by\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 569.531px; height: 29px;\">\n\u003cp>NAAC with &lsquo;A&rsquo; grade\u003c/p>\n\u003c/td>\n\u003c/tr>\n\u003ctr style=\"height: 29px;\">\n\u003ctd style=\"width: 530.469px; height: 29px;\">\n\u003cp>Number of departments\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 569.531px; height: 29px;\">\n\u003cp>10+\u003c/p>\n\u003c/td>\n\u003c/tr>\n\u003ctr style=\"height: 29px;\">\n\u003ctd style=\"width: 530.469px; height: 10px;\">\n\u003cp>Total scholarships offered\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 569.531px; height: 10px;\">\n\u003cp>13\u003c/p>\n\u003c/td>\n\u003c/tr>\n\u003ctr style=\"height: 56px;\">\n\u003ctd style=\"width: 530.469px; height: 10px;\">\n\u003cp>Type of scholarship\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 569.531px; height: 10px;\">\n\u003cp>Merit-based scholarship for BTech\u003c/p>\n\u003cp>Scholarships for reserved category students\u003c/p>\n\u003c/td>\n\u003c/tr>\n\u003c/tbody>\n\u003c/table>","sectionName":"ovp_section_highlights","sectionHeading":"Centurion University Bhubaneswar Highlights 2024","categoryType":"ed_and_prod","showToc":true,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":false},"ovp_section_fAQs":{"description":"\u003cdiv id=\"faqWrapper_last\" class=\"faqWrapper manual\" contenteditable=\"false\">\n\u003cp class=\"fQ\">\u003cstrong id=\"faq_q1\">Q. Is Centurion University Bhubaneswar a recognised university campus? \u003c/strong>\u003c/p>\n\u003cdiv id=\"faq_a1\" class=\"fA\">\u003cspan style=\"font-weight: 400;\">A. Centurion University Bhubaneswar is affiliated with CUTM Paralakhemundi, which is recognised by NAAC with &lsquo;A&rsquo; grade. Established in 2005, Centurion University of Technology and Management (CUTM) is a multi-sector, private university located in Odisha, India. The main campus of CUTM is located at Paralakhemundi (Gajapati district). With over 600 expert instructors and over 20,000 students across the world, the University has other campuses located in \u003cstrong>Bhubaneswar\u003c/strong> and Visakhapatnam (or Vizianagaram) along with three regional campuses located in Rayagarh, Balangir (or Bolangir) and Balasore.\u003c/span>\u003c/div>\n\u003cp class=\"fQ\">\u003cstrong id=\"faq_q2\">Q. Which courses are offered at Centurion University Bhubaneswar? \u003c/strong>\u003c/p>\n\u003cdiv id=\"faq_a2\" class=\"fA\">\u003cspan style=\"font-weight: 400;\">A. Centurion University Bhubaneswar offers a range of diploma, UG, PG, research-level and certificate programmes offered through various departments working under it. Some of the popular courses offered this campus of CUTM include BTech, BBA, BCom, BSc, MTech, MBA and MSc among various others. Centurion University BBSR admission 2022 to all the programmes is based on scores obtained in Centurion University Entrance Exam (\u003ca>CUEE\u003c/a>) conducted by the University. Centurion University, Bhubaneswar also accepts a few nation-level entrance exam scores to provide admission in courses, including MBA, BTech, BDes, BArch and MTech. \u003c/span>\u003c/div>\n\u003cp class=\"fQ\">\u003cstrong id=\"faq_q3\">Q. What is admission process at Centurion University Bhubaneswar? \u003c/strong>\u003c/p>\n\u003cdiv id=\"faq_a3\" class=\"fA\">\u003cspan style=\"font-weight: 400;\">A. Candidates willing to take admission to Centurion University Bhubaneswar for all the UG and PG courses are required to have a valid score in CUEE test conducted by the University or course-specific entrance rest (accepted by the University) provided they meet with the minimum eligibility criteria set by the University. For diploma and certificate courses, however, admission is based on merit scores in the last qualifying exam.\u003c/span>\u003c/div>\n\u003cp class=\"fQ\">\u003cstrong id=\"faq_q4\">Q. What is CUEE stand for?\u003c/strong>\u003c/p>\n\u003cdiv id=\"faq_a4\" class=\"fA\">\u003cspan style=\"font-weight: 400;\">A. CUEE stands for Centurion University Entrance Exam. It is conducted by Centurion University (CUTM), Odisha for admissions to various undergraduate and postgraduate courses offered at the various campuses of the University. CUEE 2020 will be conducted in online mode or will be a CBT (Computer Based Test).\u003c/span>\u003c/div>\n\u003cp class=\"fQ\">\u003cstrong id=\"faq_q5\">Q. Does Centurion University Bhubaneswar campus offer residential facilities? \u003c/strong>\u003c/p>\n\u003cdiv id=\"faq_a5\" class=\"fA\">\u003cspan style=\"font-weight: 400;\">A. Yes, Bhubaneswar campus of Centurion University offers hostel facilities to the students. Some of the other campus facilities provided at \u003c/span>Centurion University Bhubaneswar are as follows:\n\u003cul>\n\u003cli>Air-conditioned classrooms\u003c/li>\n\u003cli>A fully Wi-Fi campus\u003c/li>\n\u003cli>Well-equipped Conference hall and Seminar hall\u003c/li>\n\u003cli>Library\u003c/li>\n\u003cli>Transport and Medical facilities\u003c/li>\n\u003cli>Full-time internet connectivity\u003c/li>\n\u003c/ul>\n\u003c/div>\n\u003cp class=\"fQ\">\u003cstrong id=\"faq_q6\">Q. Does Centurion University Bhubaneswar have any industrial collaborations? \u003c/strong>\u003c/p>\n\u003cdiv id=\"faq_a6\" class=\"fA\">\u003cspan style=\"font-weight: 400;\">A. Yes, a number of programmes such as JAVA certification in association with IBM, Network Certification in association with CISCO, DB2 training Certification in association with IBM, and Campus Connect in association with Infosys are organized for the active development of students on regular intervals.\u003c/span>\u003c/div>\n\u003cp class=\"fQ\">\u003cstrong id=\"faq_q7\">Q. What is the application process at Centurion University Bhubaneswar? \u003c/strong>\u003c/p>\n\u003cdiv id=\"faq_a7\" class=\"fA\">\u003cspan style=\"font-weight: 400;\">A. \u003c/span>Centurion University's admission process is conducted both online and offline. Candidates seeking admission to any of the courses, need to apply on the official website by paying an amount of INR 600 to INR 1,500. The entire application process is shown below with the help of application screenshots: \u003cstrong>Step 1\u003c/strong>: Visit the official website (www.cutm.ac.in). On its homepage, register yourself by providing an email id. \u003cstrong>Step 2:\u003c/strong> Fill up the application form by providing all your personal details. \u003cstrong>Step 3:\u003c/strong> Complete the form by providing your educational qualifications and press submit.  \u003cstrong>Step 4:\u003c/strong> Pay online through net banking/ debit card/ credit card.\u003c/div>\n\u003cp class=\"fQ\">\u003cstrong id=\"faq_q8\">Q. How is Centurion University Bhubaneswar in terms of foreign exposure? \u003c/strong>\u003c/p>\n\u003cdiv id=\"faq_a8\" class=\"fA\">\u003cspan style=\"font-weight: 400;\">A. Centurion University Bhubaneswar has signed MoUs with a number of international institutes and universities to offer world-class education and global exposure to its students at the central level across all its campuses. Some of the Universities CUTM is having tie-ups with include, University of California, Deakin University (Australia), Plymouth University (England), Box Hill Institute (Australia) and Holmesglen Institute (Australia) among various others.\u003c/span>\u003c/div>\n\u003cp class=\"fQ\">\u003cstrong id=\"faq_q9\">Q. Are there any scholarships offered at Centurion University Bhubaneswar? \u003c/strong>\u003c/p>\n\u003cdiv id=\"faq_a9\" class=\"fA\">\u003cspan style=\"font-weight: 400;\">A. Centurion University of Technology and Management, Bhubaneswar offers various scholarships based on prior academic record during admission and a few scholarships based on semester-wise performance for the years to follow. \u003c/span>In addition to these, ample scholarships are offered to reserved and minority category students as listed below:\n\u003cul>\n\u003cli>PRERANA post-matric scholarship for SC/ST/OBC and SEBC District Welfare Office (Odisha)\u003c/li>\n\u003cli>Minority scholarship from District Welfare Office (Odisha)\u003c/li>\n\u003cli>National scholarship\u003c/li>\n\u003cli>Jindal Foundation scholarship (Sitaram Jindal)\u003c/li>\n\u003cli>Times of India scholarship\u003c/li>\n\u003c/ul>\n\u003c/div>\n\u003cp class=\"fQ\">\u003cstrong id=\"faq_q10\">Q. How are the placements at Centurion University Bhubaneswar? \u003c/strong>\u003c/p>\n\u003cdiv id=\"faq_a10\" class=\"fA\">\u003cspan style=\"font-weight: 400;\">A. CUTM has a centralised placement cell operating from the main campus. Some of the t\u003c/span>op recruiters that have visited Centurion University Bhubaneswar campus for placements include Infosys, IBM, Cognizant, IndiaMart, Accolite Digital, Paytm, LensKart, Volvo and Mindtree, among others. \u003c/div>\n\u003c/div>","sectionName":"ovp_section_fAQs","sectionHeading":"Centurion University Bhubaneswar FAQs","categoryType":"editorial","showToc":true,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":false},"ovp_section_scholarships":{"description":"\u003cp>Centurion University of Technology and Management, Bhubaneswar offers various scholarships based on prior academic record during admission and a few scholarships based on semester-wise performance for the years to follow. For BTech programme, candidates from different board of education are given a pre-defined percentage of scholarship in their fee as mentioned in the below table:\u003c/p>\n\u003ctable style=\"width: 1133px;\">\n\u003ctbody>\n\u003ctr>\n\u003cth style=\"width: 163.156px;\">\u003cstrong>Board\u003c/strong>\u003c/th>\n\u003cth style=\"width: 560.5px;\">\u003cstrong>For 10% Scholarship (scores in %)\u003c/strong>\u003c/th>\n\u003cth style=\"width: 357.344px;\">\u003cstrong>For 15% Scholarship (scores in %)\u003c/strong>\u003c/th>\n\u003c/tr>\n\u003ctr>\n\u003ctd style=\"width: 163.156px;\">\n\u003cp>Odisha\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 560.5px;\">\n\u003cp>50-59\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 357.344px;\">\n\u003cp>60 or above\u003c/p>\n\u003c/td>\n\u003c/tr>\n\u003ctr>\n\u003ctd style=\"width: 163.156px;\">\n\u003cp>AP\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 560.5px;\">\n\u003cp>70-79\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 357.344px;\">\n\u003cp>80 or above\u003c/p>\n\u003c/td>\n\u003c/tr>\n\u003ctr>\n\u003ctd style=\"width: 163.156px;\">\n\u003cp>CBSE/Others\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 560.5px;\">\n\u003cp>50-59\u003c/p>\n\u003c/td>\n\u003ctd style=\"width: 357.344px;\">\n\u003cp>60 or above\u003c/p>\n\u003c/td>\n\u003c/tr>\n\u003c/tbody>\n\u003c/table>\n\u003cp>From the second year onwards, candidates must get a minimum of 8.0 CGPA in their semester exams along with a minimum of 80% attendance to continue with their scholarship.\u003c/p>\n\u003cp>In addition to these, ample scholarships are offered to reserved and minority category students as listed below:\u003c/p>\n\u003cul>\n\u003cli>PRERANA post-matric scholarship for SC/ST/OBC and SEBC District Welfare Office (Odisha)\u003c/li>\n\u003cli>Minority scholarship from District Welfare Office (Odisha)\u003c/li>\n\u003cli>National scholarship\u003c/li>\n\u003cli>Jindal Foundation scholarship (Sitaram Jindal)\u003c/li>\n\u003cli>Times of India scholarship\u003c/li>\n\u003cli>Ministry of Human Development (DHE) New Delhi\u003c/li>\n\u003cli>Bihar Welfare (Post-Matric) SC/ST/OBC and Minority\u003c/li>\n\u003cli>BEML scholarship (SC &amp; ST)\u003c/li>\n\u003cli>FAEA scholarship (SC &amp; ST)\u003c/li>\n\u003cli>Bihar Welfare (Technical Stipend)\u003c/li>\n\u003cli>E-KALYAN scholarship offered by Jharkhand State Welfare Department\u003c/li>\n\u003cli>Departmental/ Official scholarship from East Coast Railway/ CRPF/ Central Schools/ SBI/ Coal India/ Daitari Mines/OMC for their wards\u003c/li>\n\u003c/ul>","sectionName":"ovp_section_scholarships","sectionHeading":"Centurion University Bhubaneswar Scholarships 2024","categoryType":"ed_else_prod","showToc":true,"childPageUrl":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/scholarships","isPwa":true,"entityId":null,"productized":false},"ovp_section_popular_courses":{"description":null,"sectionName":"ovp_section_popular_courses","sectionHeading":"Centurion University Bhubaneswar Popular Programmes 2024","categoryType":"ed_and_prod","showToc":true,"childPageUrl":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/courses","isPwa":true,"entityId":null,"productized":false},"ovp_section_feedback_widget":{"description":null,"sectionName":"ovp_section_feedback_widget","sectionHeading":"","categoryType":"productized","showToc":false,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":true},"ovp_section_application_process":{"description":null,"sectionName":"ovp_section_application_process","sectionHeading":"Application process","categoryType":"editorial","showToc":true,"childPageUrl":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/admission","isPwa":true,"entityId":null,"productized":true},"ovp_section_college_comparison":{"description":null,"sectionName":"ovp_section_college_comparison","sectionHeading":"College comparison","categoryType":"editorial","showToc":true,"childPageUrl":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/compare","isPwa":true,"entityId":null,"productized":true},"ovp_section_reviews":{"description":null,"sectionName":"ovp_section_reviews","sectionHeading":"Student Reviews","categoryType":"productized","showToc":true,"childPageUrl":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/reviews","isPwa":true,"entityId":null,"productized":true},"ovp_section_results":{"description":null,"sectionName":"ovp_section_results","sectionHeading":"Results","categoryType":"editorial","showToc":true,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":true},"ovp_section_notable_alumni":{"description":"\u003cp>Following are a few USPs of Centurion University:\u003c/p>\n\u003cul>\n\u003cli>Integrating Higher Education with Skills to Produce a More employable workforce.\u003c/li>\n\u003cli>Having On Campus Product Manufacturing Units to give students the real-time Industry Experience\u003c/li>\n\u003cli>We offer 60 Domain Specializations in Various Areas\u003c/li>\n\u003cli>Having 50+ Patents in various areas.\u003c/li>\n\u003cli>Having 60+ Industry Sponsored Action Research Centres and Action Learning Labs.\u003c/li>\n\u003cli>Excellent Sports Infrastructure Promoting students for state-level and National Level Championships.\u003c/li>\n\u003cli>Mentorship, funding (investment ), market linkage to working space, and infrastructure (equipment, high-performance computing lab, design centre) support for promising start-up ideas through a dedicated Center of Innovation and Entrepreneurship\u003c/li>\n\u003cli>Degrees integrated with leading companies such as Dassault Systemes and AWS leading to graduation with an industry certificate.\u003c/li>\n\u003cli>In Campus Boys and Girls hostel facilities for 10,000+ students along with AC &amp; Non AC Accommodation and best-of-class mess facility.\u003c/li>\n\u003cli>Choice-based credit system and a Unique Skills for Success program to ensure a high success rate and employability.\u003c/li>\n\u003cli>University which brings diversity with students &amp; faculties from 10 nations and all Indian states.\u003c/li>\n\u003cli>A University which beliefs in Women Empowerment by having females at Top leadership positions.\u003c/li>\n\u003c/ul>","sectionName":"ovp_section_notable_alumni","sectionHeading":"Centurion University Bhubaneswar USPs","categoryType":"editorial","showToc":true,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":false},"ovp_section_placements":{"description":"\u003cp>The final placements for all campuses of CUTM are managed and monitored by its designated centralised Career Development Cell (CDC). CDC conducts a number of career counseling and training programmes for the students and also monitors the recruitment activities at every campus. It organises a range of programmes such as JAVA certification in association with IBM, Network Certification in association with CISCO, DB2 training Certification in association with IBM, and Campus Connect in association with Infosys for the active development of students at regular intervals.\u003c/p>\n\u003cp>The University has also signed MoUs with a number of companies such as Yamaha, Godrej, VOLVO Eicher, Hyundai Motors Pvt Ltd and Tata Automation Limited for the benefits of its students. Some of the key recruiters that have hired the students of this University during 2022 placements include the following:\u003c/p>\n\u003ctable style=\"height: 113px;\">\n\u003ctbody>\n\u003ctr style=\"height: 29px;\">\n\u003cth style=\"width: 1156px; height: 29px;\" colspan=\"3\">\n\u003cp>\u003cstrong>Centurion University Bhubaneswar Top Recruiters\u003c/strong>\u003c/p>\n\u003c/th>\n\u003c/tr>\n\u003ctr style=\"height: 21px;\">\n\u003ctd style=\"width: 361.641px; height: 21px;\">Infosys\u003c/td>\n\u003ctd style=\"width: 385.672px; height: 21px;\">IndiaMart\u003c/td>\n\u003ctd style=\"width: 374.688px; height: 21px;\">Accolite Digital\u003c/td>\n\u003c/tr>\n\u003ctr style=\"height: 21px;\">\n\u003ctd style=\"width: 361.641px; height: 21px;\">IBM\u003c/td>\n\u003ctd style=\"width: 385.672px; height: 21px;\">Paytm\u003c/td>\n\u003ctd style=\"width: 374.688px; height: 21px;\">LensKart\u003c/td>\n\u003c/tr>\n\u003ctr style=\"height: 21px;\">\n\u003ctd style=\"width: 361.641px; height: 21px;\">Cognizant\u003c/td>\n\u003ctd style=\"width: 385.672px; height: 21px;\">Volvo\u003c/td>\n\u003ctd style=\"width: 374.688px; height: 21px;\">Mindtree\u003c/td>\n\u003c/tr>\n\u003c/tbody>\n\u003c/table>","sectionName":"ovp_section_placements","sectionHeading":"Centurion University Bhubaneswar Placements 2024","categoryType":"ed_and_prod","showToc":true,"childPageUrl":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/placement","isPwa":true,"entityId":null,"productized":false},"ovp_section_cutoff":{"description":null,"sectionName":"ovp_section_cutoff","sectionHeading":"Cut Offs 2024","categoryType":"ed_and_prod","showToc":true,"childPageUrl":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/cutoff","isPwa":true,"entityId":null,"productized":true},"ovp_section_fees_and_eligibility":{"description":"\u003cp>Centurion University Bhubaneswar offers a range of diploma, UG, PG, research-level and certificate programmes offered through multiple departments working under it. Some of the popular courses offered at Centurion University Bhubaneswar are mentioned in below table along with their eligibility criteria and yearly fee structure:\u003c/p>","sectionName":"ovp_section_fees_and_eligibility","sectionHeading":"Centurion University Bhubaneswar Courses and Fees 2024","categoryType":"ed_and_prod","showToc":true,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":false},"ovp_section_other_popular_GOCs":{"description":null,"sectionName":"ovp_section_other_popular_GOCs","sectionHeading":"","categoryType":"productized","showToc":false,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":true},"ovp_section_affiliated_colleges/departments":{"description":"\u003cp>The Bhubaneswar department of CUTM is offering courses across multiple streams such as Engineering Management and Science among various others with the help of its 11 departments mentioned as follows:\u003c/p>\n\u003cdiv class=\"photo-widget-full\">\n\u003cdiv class=\"figure\">\u003cimg style=\"margin: 0px !important;\" src=\"https://images.shiksha.com/mediadata/images/articles/1593581043phpfmGS9g.jpeg\" width=\"1138\" height=\"900\" />\u003c/div>\n\u003c/div>","sectionName":"ovp_section_affiliated_colleges/departments","sectionHeading":"Centurion University Bhubaneswar Departments","categoryType":"ed_and_prod","showToc":true,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":false},"ovp_section_about_college":{"description":"\u003cp>GATE 2024 exam will be conducted between \u003cstrong>Feb 3, 2024\u003c/strong> and \u003cstrong>Feb 11, 2024\u003c/strong>.\u003c/p>","sectionName":"ovp_section_about_college","sectionHeading":"Introduction","categoryType":null,"showToc":false,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":false},"ovp_section_faculty":{"description":null,"sectionName":"ovp_section_faculty","sectionHeading":"Faculty","categoryType":"editorial","showToc":true,"childPageUrl":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/faculty","isPwa":true,"entityId":null,"productized":true},"ovp_section_dfp_ada_3_and_4":{"description":null,"sectionName":"ovp_section_dfp_ada_3_and_4","sectionHeading":"","categoryType":"productized","showToc":false,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":true},"ovp_section_billboard":{"description":null,"sectionName":"ovp_section_billboard","sectionHeading":"","categoryType":"productized","showToc":false,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":true},"ovp_section_reco_widget_1":{"description":null,"sectionName":"ovp_section_reco_widget_1","sectionHeading":"","categoryType":"productized","showToc":false,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":true},"ovp_section_infrastructure":{"description":"\u003cp>Centurion University Bhubaneswar has classrooms, a library, hostels, and cafeterias. Some of the campus facilities include:\u003c/p>\n\u003cul>\n\u003cli>Air-conditioned classrooms\u003c/li>\n\u003cli>A fully Wi-Fi campus\u003c/li>\n\u003cli>Well-equipped Conference hall and Seminar hall\u003c/li>\n\u003cli>Library\u003c/li>\n\u003cli>Transport and Medical facilities\u003c/li>\n\u003cli>Full-time internet connectivity\u003c/li>\n\u003cli>Hostels facility for boys &amp; girls\u003c/li>\n\u003c/ul>","sectionName":"ovp_section_infrastructure","sectionHeading":"Centurion University Bhubaneswar Infrastructure","categoryType":"ed_and_prod","showToc":true,"childPageUrl":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/infrastructure","isPwa":true,"entityId":null,"productized":false},"ovp_section_reco_widget_2":{"description":null,"sectionName":"ovp_section_reco_widget_2","sectionHeading":"","categoryType":"productized","showToc":false,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":true},"ovp_section_dfp_ada_5_and_6":{"description":null,"sectionName":"ovp_section_dfp_ada_5_and_6","sectionHeading":"","categoryType":"productized","showToc":false,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":true},"ovp_section_dfp_ada_1_and_2":{"description":null,"sectionName":"ovp_section_dfp_ada_1_and_2","sectionHeading":"","categoryType":"productized","showToc":false,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":true},"ovp_section_similar_webinar":{"description":null,"sectionName":"ovp_section_similar_webinar","sectionHeading":"","categoryType":"productized","showToc":false,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":true},"ovp_section_comments":{"description":null,"sectionName":"ovp_section_comments","sectionHeading":"Student Forum","categoryType":"productized","showToc":false,"childPageUrl":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/questions","isPwa":false,"entityId":null,"productized":true},"ovp_section_admission_dates":{"description":null,"sectionName":"ovp_section_admission_dates","sectionHeading":"Centurion University Bhubaneswa Admission Dates 2024","categoryType":"ed_and_prod","showToc":true,"childPageUrl":"/college/centurion-university-of-technology-and-management-bhubaneswar-campus-53057/admission","isPwa":true,"entityId":null,"productized":false},"ovp_section_assistant_card":{"description":null,"sectionName":"ovp_section_assistant_card","sectionHeading":"","categoryType":"productized","showToc":false,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":true},"ovp_section_collaboration_and_partnerships":{"description":null,"sectionName":"ovp_section_collaboration_and_partnerships","sectionHeading":"Collaboration and partnerships","categoryType":"editorial","showToc":true,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":true},"ovp_section_rankings":{"description":null,"sectionName":"ovp_section_rankings","sectionHeading":"Rankings 2024","categoryType":"ed_and_prod","showToc":true,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":true},"ovp_section_others":{"description":null,"sectionName":"ovp_section_others","sectionHeading":"Additional details","categoryType":"editorial","showToc":false,"childPageUrl":null,"isPwa":null,"entityId":null,"productized":true}},"pageLevelSectionOrder":["